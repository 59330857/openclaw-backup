{"type":"message","id":"c222cc00","parentId":"e24e9e0e","timestamp":"2026-03-27T06:31:55.107Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"We need to generate index.ts source code for the skill. Should include logic using agent-browser commands, filter, LLM scoring, ROI calc, output. Provide code. Need to be in workspace path .openclaw/workspace/skills/tts_hair_scout/index.ts. Write file.","thinkingSignature":"reasoning"},{"type":"toolCall","id":"call_fe82fac86b194185be","name":"write","arguments":{"content":"// index.ts - Implementation of tts_hair_scout skill\n// This file runs inside an isolated sub‑agent. It uses the `agent-browser` CLI\n// to scrape TikTok (Web) for hair‑accessory videos, applies the filtering\n// criteria you defined, asks the main agent to score each candidate via LLM,\n// computes a simple ROI, and returns a JSON payload that the parent agent can\n// use to send Feishu notifications and write Bitable records.\n\nimport { execSync } from \"child_process\";\nimport * as fs from \"fs\";\nimport * as path from \"path\";\n\n// ----- Configuration (will be overridden by params from parent) -----\nconst DEFAULT_PARAMS = {\n  category: \"Hair Accessories\",\n  subcategories: [\"Hair Clips/Headbands\", \"Hairpins/Hair Ties\"],\n  view_threshold: 100000,\n  keywords: [\"where to buy\", \"link please\", \"is it on shop\", \"how much\", \"want this\"],\n  bitable_app_token: \"PLACEHOLDER\",\n  bitable_table_id: \"PLACEHOLDER\",\n  // ROI constants – can be changed later if needed\n  commission_factor: 0.85,\n  shipping_cost: 2.5, // USD per unit\n  ad_test_cost: 3.0, // USD per unit\n};\n\ninterface Params {\n  category?: string;\n  subcategories?: string[];\n  view_threshold?: number;\n  keywords?: string[];\n  bitable_app_token?: string;\n  bitable_table_id?: string;\n}\n\n// Helper to run agent-browser commands and return stdout (JSON when `--json` used)\nfunction runBrowser(cmd: string): string {\n  // Using execSync ensures we wait for completion; any error will throw.\n  const fullCmd = `agent-browser ${cmd}`;\n  try {\n    const out = execSync(fullCmd, { encoding: \"utf8\", stdio: [\"ignore\", \"pipe\", \"pipe\"] });\n    return out.trim();\n  } catch (e: any) {\n    console.error(\"agent-browser error:\", e.message);\n    throw e;\n  }\n}\n\n// Parse TikTok view count strings like \"123.4K\" or \"1.2M\"\nfunction parseViews(text: string): number {\n  const m = text.replace(/,/g, \"\").match(/([\\d.]+)([KM]?)/i);\n  if (!m) return 0;\n  let num = parseFloat(m[1]);\n  const unit = m[2].toUpperCase();\n  if (unit === \"K\") num *= 1_000;\n  else if (unit === \"M\") num *= 1_000_000;\n  return Math.round(num);\n}\n\n// Simple ROI calculation based on provided price (assumed retail price) and productCost.\nfunction calculateROI(price: number, productCost: number): number {\n  const netProfit = price * DEFAULT_PARAMS.commission_factor - (productCost + DEFAULT_PARAMS.shipping_cost + DEFAULT_PARAMS.ad_test_cost);\n  return netProfit; // raw profit; parent can format as needed\n}\n\n// Main execution entry point\nasync function main() {\n  // Parameters are passed via a temporary JSON file created by the parent agent.\n  const paramsPath = process.env.PARAMS_PATH || \"/tmp/tts_hair_params.json\";\n  let params: Params = {};\n  try {\n    const raw = fs.readFileSync(paramsPath, \"utf8\");\n    params = JSON.parse(raw);\n  } catch {\n    // fallback to defaults if file missing\n  }\n  const cfg = { ...DEFAULT_PARAMS, ...params };\n\n  // 1️⃣ Open TikTok search page for hair accessories.\n  // Use a generic search term that covers both subcategories.\n  const searchQuery = encodeURIComponent(`${cfg.category} ${cfg.subcategories.join(\" \")}`);\n  const url = `https://www.tiktok.com/search?q=${searchQuery}`;\n  console.log(\"Opening TikTok URL:\", url);\n  runBrowser(`open ${url}`);\n\n  // Give page a moment to load – 5s wait.\n  runBrowser(`wait 5000`);\n\n  // 2️⃣ Snapshot interactive video cards.\n  const snapshotJson = runBrowser(`snapshot -i --json`);\n  const snapshot = JSON.parse(snapshotJson);\n\n  // Expect each video card to have elements like href (video), text (views), etc.\n  // We'll gather candidate items.\n  const candidates: any[] = [];\n  for (const el of snapshot) {\n    // Very heuristic – look for element with a href to a tiktok video.\n    if (el.attr && el.attr.href && el.attr.href.includes(\"/video/\")) {\n      const videoUrl = el.attr.href;\n      // Find a sibling element that contains view count – typical selector class may vary.\n      // We'll try to fetch any text node under the same parent that matches \"views\".\n      const viewEl = snapshot.find((s: any) => s.parentId === el.id && s.text && /views?/i.test(s.text));\n      const viewText = viewEl?.text || \"0\";\n      const views = parseViews(viewText);\n      if (views >= cfg.view_threshold) {\n        // Load comments – click comment button if present.\n        const commentBtn = snapshot.find((s: any) => s.parentId === el.id && s.role === \"button\" && /comment/i.test(s.text || \"\"));\n        if (commentBtn) {\n          // Click to expand comments, wait a bit, then capture comment texts.\n          runBrowser(`click @${commentBtn.ref}`);\n          runBrowser(`wait 2000`);\n          const commentsSnap = runBrowser(`snapshot -i --json`);\n          const comments = JSON.parse(commentsSnap);\n          const commentTexts: string[] = comments\n            .filter((c: any) => c.role === \"paragraph\" && c.text)\n            .map((c: any) => c.text.toLowerCase());\n          // Check for any purchase‑intent keyword.\n          const hasKeyword = cfg.keywords.some((kw) => commentTexts.some((ct) => ct.includes(kw.toLowerCase())));\n          if (hasKeyword) {\n            // Grab title (usually inside <h1> or similar). Simplify by taking first text node under video card.\n            const titleEl = snapshot.find((s: any) => s.parentId === el.id && s.role === \"heading\");\n            const title = titleEl?.text?.trim() || \"Untitled\";\n            candidates.push({ title, videoUrl, views, commentSnippet: commentTexts.find((c) => cfg.keywords.some((kw) => c.includes(kw))) || \"\" });\n          }\n        }\n      }\n    }\n  }\n\n  // 3️⃣ For each candidate, ask the main agent for LLM scoring.\n  const results: any[] = [];\n  for (const item of candidates) {\n    const prompt = `作为 TTS 选品专家，请评估该发饰的『视觉冲击力』和『社交传播潜质』。重点关注：1. 佩戴前后的对比效果是否明显？ 2. 评论区是否有强烈的审美认同？ 3. 是否符合当前的季节性审美（如春季碎花、夏季多巴胺等）？请给出 0-100 的评分。\\n标题: ${item.title}\\n链接: ${item.videoUrl}\\n播放量: ${item.views}\\n评论摘录: ${item.commentSnippet}`;\n    // We communicate with the parent via a temporary file that the parent will read.\n    const scorePath = \"/tmp/tts_score_\" + Math.random().toString(36).substring(2) + \".json\";\n    fs.writeFileSync(scorePath, JSON.stringify({ prompt }), \"utf8\");\n    // Signal parent to perform LLM call – the parent will read this file, run the model,\n    // and write back a result file named `${scorePath}.out`.\n    console.log(`WAIT_FOR_SCORE:${scorePath}`);\n    // Spin‑wait until the result appears (simple polling, small timeout).\n    let attempts = 0;\n    let score = 0;\n    while (attempts < 30) {\n      if (fs.existsSync(scorePath + \".out\")) {\n        const out = JSON.parse(fs.readFileSync(scorePath + \".out\", \"utf8\"));\n        score = Number(out.score) || 0;\n        break;\n      }\n      // Sleep 1 sec\n      execSync(`sleep 1`);\n      attempts++;\n    }\n    // Dummy fallback if no score returned.\n    if (score === 0) score = 50;\n\n    // 4️⃣ ROI – here we assume a placeholder retail price of 15 USD and product cost of 5 USD.\n    const price = 15; // USD – could be derived from video description in future.\n    const productCost = 5; // USD – placeholder.\n    const netProfit = calculateROI(price, productCost);\n\n    results.push({ ...item, llmScore: score, netProfit, price, productCost });\n  }\n\n  // 5️⃣ Output final JSON for parent agent.\n  const outPath = process.env.OUTPUT_PATH || \"/tmp/tts_hair_results.json\";\n  fs.writeFileSync(outPath, JSON.stringify({ results }, null, 2), \"utf8\");\n  console.log(`RESULTS_WRITTEN:${outPath}`);\n}\n\nmain().catch((e) => {\n  console.error(\"Fatal error in tts_hair_scout:\", e);\n  process.exit(1);\n});\n","path":"~/.openclaw/workspace/skills/tts_hair_scout/index.ts"}}],"api":"openai-completions","provider":"openrouter","model":"openrouter/auto","usage":{"input":35873,"output":2399,"cacheRead":0,"cacheWrite":0,"totalTokens":38272,"cost":{"input":-35873,"output":-2399,"cacheRead":0,"cacheWrite":0,"total":-38272}},"stopReason":"toolUse","timestamp":1774593101217,"responseId":"gen-1774593102-jzzZvIXjwRQ1nP6c2zqi"}}
