ax\"\n    },\n    {\n      \"id\": \"MiniMax-M2.1\",\n      \"object\": \"model\",\n      \"created\": 1766455200,\n      \"owned_by\": \"minimax\"\n    },\n    {\n      \"id\": \"MiniMax-M2.1-highspeed\",\n      \"object\": \"model\",\n      \"created\": 1766455200,\n      \"owned_by\": \"minimax\"\n    },\n    {\n      \"id\": \"MiniMax-M2\",\n      \"object\": \"model\",\n      \"created\": 1761530400,\n      \"owned_by\": \"minimax\"\n    }\n  ]\n}","cwd":"/home/halei/.openclaw/workspace"},"isError":false,"timestamp":1778060781587}}
{"type":"message","id":"f5f37313","parentId":"5fe1277b","timestamp":"2026-05-06T09:46:27.228Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"MiniMax doesn't expose embedding models via the `/v1/models` endpoint. They have a separate embedding API. Let me check the MiniMax documentation or try to call their embedding endpoint with the correct parameters.\n\nActually, looking at this more carefully, MiniMax has a separate API for embeddings that's not OpenAI-compatible. The `/v1/embeddings` endpoint exists but uses MiniMax-specific parameters.\n\nLet me try calling it with the correct MiniMax format (using `texts` instead of `input`).","thinkingSignature":"a7a8700d54817d1da1726f026db18009a5670c286773a9da54e1d1a4f4d147db"},{"type":"toolCall","id":"call_function_q8inn6x9bm0z_1","name":"exec","arguments":{"command":"curl -s --max-time 10 \"https://api.minimaxi.com/v1/embeddings\" \\\n  -H \"Authorization: Bearer sk-cp-gtdRxxiZ_Qu_-9GM0xBF6UpeDvsYl8cPe4Y9mA-Xiy2GO8eBJSNPftqJdMb0Fl9OZAkY6sQR868fRUhTBV7OtwKyDfu-DzegI9-cDZERwbQGf3C5Wuvs38c\" \\\n  -H \"Content-Type: application/json\" \\\n  -d '{\"model\":\"embo-01\",\"texts\":[\"hello\"]}' 2>&1","timeout":15}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":60348,"output":285,"cacheRead":21794,"cacheWrite":0,"totalTokens":82427,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1778060781593,"responseId":"064a40ed1cb85b709d909f0605c114bd"}}
