n      \"installPath\": \"/home/halei/.openclaw/extensions/openclawwechat\",\n      \"version\": \"1.2.5\",\n      \"resolvedName\": \"openclawwechat\",\n      \"resolvedVersion\": \"1.2.5\","}],"details":{"status":"completed","exitCode":0,"durationMs":58,"aggregated":"{\n  \"slots\": {\n    \"memory\": \"memory-core\"\n  },\n  \"allow\": [\n    \"openclawwechat\",\n    \"openclaw-weixin\",\n    \"memory-lancedb\",\n    \"minimax\",\n    \"openclaw-lark\",\n    \"browser\",\n    \"openviking\",\n    \"openrouter\",\n    \"feishu\",\n    \"memory-core\"\n  ],\n  \"entries\": {\n    \"feishu\": {\n      \"enabled\": false\n    },\n    \"openclawwechat\": {\n      \"enabled\": true,\n      \"config\": {\n        \"pollIntervalMs\": 5000,\n        \"sessionKey\": \"agent:main:main\",\n        \"debug\": false\n      }\n    },\n    \"openclaw-weixin\": {\n      \"enabled\": true,\n      \"config\": {}\n    },\n    \"memory-lancedb\": {\n      \"enabled\": true,\n      \"config\": {\n        \"embedding\": {\n          \"apiKey\": \"sk-cp-gtdRxxiZ_Qu_-9GM0xBF6UpeDvsYl8cPe4Y9mA-Xiy2GO8eBJSNPftqJdMb0Fl9OZAkY6sQR868fRUhTBV7OtwKyDfu-DzegI9-cDZERwbQGf3C5Wuvs38c\",\n          \"model\": \"text-embedding-3-small\"\n        },\n        \"dbPath\": \"/home/halei/.openclaw/memory/lancedb-pro\"\n      }\n    },\n    \"openviking\": {\n      \"enabled\": true,\n      \"config\": {\n        \"mode\": \"remote\",\n        \"baseUrl\": \"http://localhost:1933\",\n        \"apiKey\": \"openviking2024\",\n        \"agentId\": \"default\"\n      }\n    },\n    \"minimax\": {\n      \"enabled\": true\n    },\n    \"openclaw-lark\": {\n      \"enabled\": true\n    },\n    \"memory-core\": {\n      \"enabled\": true,\n      \"config\": {\n        \"dreaming\": {\n          \"enabled\": true\n        }\n      }\n    },\n    \"browser\": {\n      \"enabled\": true\n    },\n    \"openrouter\": {\n      \"enabled\": true\n    }\n  },\n  \"installs\": {\n    \"openclawwechat\": {\n      \"source\"