oducts:\n    days = days_from(p.get('上架日期','2000-01-01'))\n    price = float(p.get('价格',0))\n    reviews = int(p.get('评论数','0') or 0)\n    monthly = int(p.get('月销量','0') or 0)\n    if days <= 30 and 3 <= price <= 10 and 50 <= reviews <= 10000 and monthly >= 50:\n        recent.append(p)\n\nprint(f'近30天符合条件: {len(recent)}')\nfor i, p in enumerate(recent[:10]):\n    print(f\\\"{i+1}. {p['标题'][:55]}\\\")\n    print(f\\\"   上架:{p['上架日期']}({days_from(p['上架日期'])}天) 月销:{p['月销量']} 价:\\${p['价格']} 评价:{p['评论数']}\\\")\n\""}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":436,"output":687,"cacheRead":78208,"cacheWrite":0,"totalTokens":79331,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1780454049160,"responseId":"066ec5a1ba28a5e44752a8b478f29fbc"}}
