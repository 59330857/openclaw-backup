{"type":"message","id":"509206e5","parentId":"cb3acd82","timestamp":"2026-06-03T02:28:55.004Z","message":{"role":"toolResult","toolCallId":"call_function_am1l3e4ti6k7_1","toolName":"exec","content":[{"type":"text","text":"sorftime-mcp\n\n  /**\n   * 查询我的Shopee平台关键词词库的词\n   *\n   * @param dict? 选填，如果指定，查询指定收藏夹下的词；如需查询全部词，指定传值`all`\n   * @param page? 查询结果的页码索引，默认为第1页。每页返回100条数据\n   * @param site? Shopee站点，支持：201:VN，202:ID，203:SG，204:TH，205:MY，206:TW，207:PH，208:BR\n   */\n  function shopee_get_favorite_keyword(dict?: string, page?: number, site?: \"UnKonw\" | \"VN\" | \"ID\" | \"SG\" | \"TH\" | \"MY\" | \"TW\" | \"PH\" | \"BR\");\n\n  /**\n   * 查询Tiktok平台产品详情\n   *\n   * @param productId 产品Id\n   * @param site? TikTok站点\n   */\n  function tiktok_product_detail(productId: string, site?: \"Unknow\" | \"US\" | \"MY\" | \"PH\" | \"VN\" | \"ID\" | \"GB\");\n\n  /**\n   * 搜索亚马逊电商平台上的潜力产品\n   *\n   * @param searchName? 可选参数，如果指定，将按此名称搜索相关产品\n   * @param price_min? 可选参数，如果指定表示筛选销售价大于等于此值的产品\n   * @param price_max? 可选参数，如果指定表示筛选销售价小于等于此值的产品\n   * @param month_sales_volume_min? 可选参数，如果指定表示筛选月销量大于等于此值的产品\n   * @param month_sales_volume_max? 可选参数，如果指定表示筛选月销量小于等于此值的产品\n   * @param delivery_type? 可选参数，如果指定，筛选产品的发货方式\n   * @param page? 查询结果的页码索引，默认为第1页。每页返回20条数据\n   * @param amzSite? 亚马逊站点\n   */\n  function potential_product(searchName?: string, price_min?: number, price_max?: number, month_sales_volume_min?: number, month_sales_volume_max?: number);\n  // optional (3): delivery_type, page, amzSite\n\n  /**\n   * 查询Tiktok平台产品趋势，同时返回`销量`，`价格`，`星级`，`评论数量`，`新增带货视频数`，`新增带货达人数`多个维度\n   *\n   * @param productId 产品Id\n   * @param site? TikTok站点\n   */\n  function tiktok_product_trend(productId: string, site?: \"Unknow\" | \"US\" | \"MY\" | \"PH\" | \"VN\" | \"ID\" | \"GB\");\n\n  /**\n   * 移动我的Shopee平台关键词词库中收藏的关键词到指定收藏夹，如果收藏夹不存在会新建\n   *\n   * @param keyword 需要移动的词\n   * @param toDict 移动到的收藏夹名称\n   * @param fromDict? 选填，如果指定，将移动指定收藏夹下的词\n   * @param site? Shopee站点，支持：201:VN，202:ID，203:SG，204:TH，205:MY，206:TW，207:PH，208:BR\n   */\n  function shopee_change_favorite_keyword(keyword: string, toDict: string, fromDict?: string, site?: \"UnKonw\" | \"VN\" | \"ID\" | \"SG\" | \"TH\" | \"MY\" | \"TW\" | \"PH\" | \"BR\");\n\n  /**\n   * 查询Shopee产品详情\n   *\n   * @param productId 需要查询的产品Id\n   * @param site? Shopee站点，支持：201:VN，202:ID，203:SG，204:TH，205:MY，206:TW，207:PH，208:BR\n   */\n  function shopee_product_request(productId: string, site?: \"UnKonw\" | \"VN\" | \"ID\" | \"SG\" | \"TH\" | \"MY\" | \"TW\" | \"PH\" | \"BR\");\n\n  /**\n   * 在我的Shopee平台关键词词库中添加关键词收藏\n   *\n   * @param keyword 需要收藏的词\n   * @param dict? 选填，如果指定，将添加词到指定收藏夹\n   * @param site? Shopee站点，支持：201:VN，202:ID，203:SG，204:TH，205:MY，206:TW，207:PH，208:BR\n   */\n  function shopee_favorite_keyword(keyword: string, dict?: string, site?: \"UnKonw\" | \"VN\" | \"ID\" | \"SG\" | \"TH\" | \"MY\" | \"TW\" | \"PH\" | \"BR\");\n\n  /**\n   * 查询亚马逊电商平台产品的子体明细\n   *\n   * @param asin 产品ASIN，仅支持单ASIN查询\n   * @param amzSite? 亚马逊站点\n   */\n  function product_variations(asin: string, amzSite?: \"Unknow\" | \"US\" | \"GB\" | \"DE\" | \"FR\" | \"IN\" | \"CA\" | \"JP\" | \"ES\" | \"IT\" | \"MX\" | \"AE\" | \"AU\" | \"BR\" | \"SA\");\n\n  /**\n   * 查询沃尔玛电商平台上热搜关键词近15日的搜索结果自然位产品清单\n   *\n   * @param keyword 查询的关键词\n   * @param page? 查询结果的页码索引，默认为第1页。每页返回20条数据\n   */\n  function walmart_keyword_search_results(keyword: string, page?: number);\n\n  /**\n   * 支持产品五大维度历史趋势：星级、评论数、价格、累计销量、近30日销量\n   *\n   * @param productId 需要查询的产品Id\n   * @param queryStart? 选填，查询趋势的时间段的开始时间，格式:yyyy-MM-dd。默认近1年。查询时间超过1年时，每次调用消耗变为10。\n   * @param queryEnd? 选填，查询趋势的时间段的结束时间，格式:yyyy-MM-dd。默认为当前时间。\n   * @param site? Shopee站点，支持：201:VN，202:ID，203:SG，204:TH，205:MY，206:TW，207:PH，208:BR\n   */\n  function shopee_product_trend(productId: string, queryStart?: string, queryEnd?: string, site?: \"UnKonw\" | \"VN\" | \"ID\" | \"SG\" | \"TH\" | \"MY\" | \"TW\" | \"PH\" | \"BR\");\n\n  /**\n   * 删除我的Shopee平台关键词词库中收藏的指定关键词\n   *\n   * @param keyword 需要删除的词\n   * @param dict? 选填，如果指定，将删除指定收藏夹下的词\n   * @param site? Shopee站点，支持：201:VN，202:ID，203:SG，204:TH，205:MY，206:TW，207:PH，208:BR\n   */\n  function shopee_del_favorite_keyword(keyword: string, dict?: string, site?: \"UnKonw\" | \"VN\" | \"ID\" | \"SG\" | \"TH\" | \"MY\" | \"TW\" | \"PH\" | \"BR\");\n\n  /**\n   * 查询Tiktok平台产品的带货达人\n   *\n   * @param productId 产品Id\n   * @param site? TikTok站点\n   */\n  function tiktok_product_video_author(productId: string, site?: \"Unknow\" | \"US\" | \"MY\" | \"PH\" | \"VN\" | \"ID\" | \"GB\");\n\n  /**\n   * 查询产品在Tiktok平台上的相似产品，可用于分析此类产品的销售情况\n   *\n   * @param searchName 查询的产品名称\n   * @param page? 查询结果的页码索引，默认为第1页。每页返回20条数据\n   * @param site? TikTok站点\n   */\n  function tiktok_similar_product(searchName: string, page?: number, site?: \"Unknow\" | \"US\" | \"MY\" | \"PH\" | \"VN\" | \"ID\" | \"GB\");\n\n  /**\n   * 查询Shopee卖家（店铺）详情\n   *\n   * @param shopId 需要查询的店铺Id\n   * @param site? Shopee站点，支持：201:VN，202:ID，203:SG，204:TH，205:MY，206:TW，207:PH，208:BR\n   */\n  function shopee_shop_request(shopId: string, site?: \"UnKonw\" | \"VN\" | \"ID\" | \"SG\" | \"TH\" | \"MY\" | \"TW\" | \"PH\" | \"BR\");\n\n  /**\n   * 搜索Shopee电商平台上的产品数据，支持多维度筛选，按月销量倒序排列\n   *\n   * @param asin? 选填，如果指定：基于ASIN查询同类产品（注意：并非只查询这个ASIN，如果需要这个产品请调用ProductRequest接口）\n   *              示例：B0CVM8TXHP\n   * @param nodeId? 选填，如果指定：基于类目查询（不限为细分类目）\n   *                示例：3743561\n   * @param priceRangeMin? 选填，如果指定：限定销售价最小值（val >= 设定值）查产品\n   *                       示例：20.00\n   * @param priceRangeMax? 选填，如果指定：限定销售价最大值（val <= 设定值）查产品\n   *                       示例：50.00\n   * @param monthSaleVolumeRangeMin? 选填，如果指定：限定月销量最小值（val >= 设定值）查产品\n   *                                 示例：500\n   * @param monthSaleVolumeRangeMax? 选填，如果指定：限定月销量最大值（val <= 设定值）查产品\n   *                                 示例：1000\n   * @param onlineDateRangeMin? 选填，如果指定：限定上架时间起始时间查产品，日期格式为yyyy-MM-dd\n   *                            示例：2025-01-01\n   * @param onlineDateRangeMax? 选填，如果指定：限定上架时间截止时间查产品，日期格式为yyyy-MM-dd\n   *                            示例：2026-01-01\n   * @param starRangeMin? 选填，如果指定：限定星级最小值查产品\n   *                      示例：4.0\n   * @param starRangeMax? 选填，如果指定：限定星级最大值查产品\n   *                      示例：4.8\n   * @param commentCountRangeMin? 选填，如果指定：限定评论数量最小值查产品\n   *                              示例：50\n   * @param commentCountRangeMax? 选填，如果指定：限定评论数量最大值查产品\n   *                              示例：500\n   * @param variationCountRangeMin? 选填，如果指定：限定子体数最小值查产品\n   *                                示例：1\n   * @param variationCountRangeMax? 选填，如果指定：限定子体数最大值查产品\n   *                                示例：10\n   * @param shopLocation? 选填，卖家来源：1：本土店，2：跨境店\n   * @param shopType? 选填，店铺类型：1：普通店，2：优选店，3：旗舰店\n   * @param site? Shopee站点，支持：201:VN，202:ID，203:SG，204:TH，205:MY，206:TW，207:PH，208:BR\n   * @param page? 分页查询，每页最多20个产品。默认为1，表示第1页 （全部结果分页从1开始，而非0）\n   *              示例：1\n   */\n  function shopee_product_search(asin?: string, nodeId?: string, priceRangeMin?: number, priceRangeMax?: number, monthSaleVolumeRangeMin?: number);\n  // optional (13): monthSaleVolumeRangeMax, onlineDateRangeMin, onlineDateRangeMax, starRangeMin, starRangeMax, ...\n\n  /**\n   * 查询亚马逊电商平台产品类目结构\n   *\n   * @param amzSite? 亚马逊站点\n   */\n  function category_tree(amzSite?: \"Unknow\" | \"US\" | \"GB\" | \"DE\" | \"FR\" | \"IN\" | \"CA\" | \"JP\" | \"ES\" | \"IT\" | \"MX\" | \"AE\" | \"AU\" | \"BR\" | \"SA\");\n\n  /**\n   * 基于名称查询亚马逊电商平台细分类目市场，返回相关细分类目的Nodeid和Name\n   *\n   * @param categoryName 需要查询的类目市场名称\n   * @param amzSite? 亚马逊站点\n   */\n  function category_name_search(categoryName: string, amzSite?: \"Unknow\" | \"US\" | \"GB\" | \"DE\" | \"FR\" | \"IN\" | \"CA\" | \"JP\" | \"ES\" | \"IT\" | \"MX\" | \"AE\" | \"AU\" | \"BR\" | \"SA\");\n\n  /**\n   * 按指定大品类（如汽车用品，家居用品）搜索亚马逊电商平台上相关的细分类目（品类）市场，按销量倒序排列返回数据。\n   *\n   * @param topNode 在指定大品类下搜索（如汽车用品，家居用品），先通过CategoryTree获取，数据类型：string\n   * @param month_sales_volume_min? 可选参数，如果指定表示筛选月销量大于等于此值的细分类目市场\n   * @param month_sales_volume_max? 可选参数，如果指定表示筛选月销量小于等于此值的细分类目市场\n   * @param ratings_min? 可选参数，如果指定表示筛选星级大于等于此值的细分类目市场\n   * @param ratings_max? 可选参数，如果指定表示筛选星级小于等于此值的细分类目市场\n   * @param ratings_count_min? 可选参数，如果指定表示筛选评论数量大于等于此值的细分类目市场\n   * @param ratings_count_max? 可选参数，如果指定表示筛选评论数量小于等于此值的细分类目市场\n   * @param price_min? 可选参数，如果指定如果指定表示筛选平均销售价（当地货币，如US为美元，FR为欧元）大于等于此值的细分类目市场\n   * @param price_max? 可选参数，如果指定如果指定表示筛选平均销售价（当地货币，如US为美元，FR为欧元）小于等于此值的细分类目市场\n   * @param seasonal_popular_product? 可选参数，如果指定表示筛选在指定月份为热销旺季的细分类目\n   * @param top3Product_sales_share_min? 可选参数，用0-1表示百分比数(如10% 为\n   *                                     0.1)。如果指定表示筛选Top3产品在Top100产品的销量占比（销量垄断系数）大于等于此值的细分类目市场\n   * @param top3Product_sales_share_max? 可选参数，用0-1表示百分比数(如10% 为\n   *                                     0.1)。如果指定表示筛选Top3产品在Top100产品的销量占比（销量垄断系数）小于等于此值的细分类目市场\n   * @param amazonOwned_sales_share_min? 可选参数，用0-1表示百分比数(如10% 为\n   *                                     0.1)。如果指定表示筛选在Top100产品中亚马逊自营产品的销量占比（卖家垄断系数）大于等于此值的细分类目市场\n   * @param amazonOwned_sales_share_max? 可选参数，用0-1表示百分比数(如10% 为\n   *                                     0.1)。如果指定表示筛选在Top100产品中亚马逊自营产品的销量占比（卖家垄断系数）小于等于此值的细分类目市场\n   * @param top100_top400_sales_share_min? 可选参数，用0-1表示百分比数(如10% 为\n   *                                       0.1)。如果指定表示筛选Top100产品在Top400产品中的销量占比（占比低表示长尾市场）大于等于此值的细分类目市场\n   * @param top100_top400_sales_share_max? 可选参数，用0-1表示百分比数(如10% 为\n   *                                       0.1)。如果指定表示筛选Top100产品在Top400产品中的销量占比（占比低表示长尾市场）小于等于此值的细分类目市场\n   * @param newproduct_sales_share_min? 可选参数，用0-1表示百分比数(如10% 为\n   *                                    0.1)。如果指定表示筛选Top100产品中上架时间在3个月内产品的销量占比（新品销量占比）大于等于此值的细分类目市场\n   * @param newproduct_sales_share_max? 可选参数，用0-1表示百分比数(如10% 为\n   *                                    0.1)。如果指定表示筛选Top100产品中上架时间在3个月内产品的销量占比（新品销量占比）小于等于此值的细分类目市场\n   * @param page? 查询结果的页码索引，默认为第1页。每页返回20条数据\n   * @param amzSite? 亚马逊站点\n   */\n  function category_search_from_top_node(topNode: string, month_sales_volume_min?: number, month_sales_volume_max?: number, ratings_min?: number, ratings_max?: number);\n  // optional (15): ratings_count_min, ratings_count_max, price_min, price_max, seasonal_popular_product, ...\n\n  /**\n   * 查询沃尔玛电商平台**指定类目**的**实时**销量Top100产品数据报告\n   *\n   * @param nodeId 细分类目nodeId，查询这个指定细分类目数据\n   */\n  function walmart_category_report_by_node_id(nodeId: string);\n\n  /**\n   * 查询亚马逊电商平台**指定类目**的**指定历史时间段**销量Top100产品数据报告\n   *\n   * @param startDate 查看历史数据，指定起始时间（格式：yyyy-MM-dd）\n   * @param endDate 查看历史数据，当指定起始时间后（startDate）后用于指定查询截止时间，支持最长40天数据组合\n   * @param nodeId 细分类目nodeid，查询这个指定细分类目数据，数据类型：string\n   * @param amzSite? 亚马逊站点\n   */\n  function category_report_from_history(startDate: string, endDate: string, nodeId: string, amzSite?: \"Unknow\" | \"US\" | \"GB\" | \"DE\" | \"FR\" | \"IN\" | \"CA\" | \"JP\" | \"ES\" | \"IT\" | \"MX\" | \"AE\" | \"AU\" | \"BR\" | \"SA\");\n\n  /**\n   * 查询亚马逊电商平台细分类目市场趋势数据，基于类目Top100产品统计\n   *\n   * @param nodeId 查询类目的nodeid，数据类型：string\n   * @param trendIndex? 所查询的趋势类型\n   * @param amzSite? 亚马逊站点\n   */\n  function category_trend(nodeId: string, trendIndex?: \"SalesCount\" | \"BrandProductCount\" | \"SellerProductCount\" | \"AvgPrice\" | \"AvgRatingCount\" | \"AvgScore\" | \"NewProductSalesAmountShare\" | \"AmazonSalesAmountShare\" | \"Top3ProductSalesAmountShare\" | \"Top3BrandSalesAmountShare\" | \"Top3SellerSalesAmountShare\", amzSite?: \"Unknow\" | \"US\" | \"GB\" | \"DE\" | \"FR\" | \"IN\" | \"CA\" | \"JP\" | \"ES\" | \"IT\" | \"MX\" | \"AE\" | \"AU\" | \"BR\" | \"SA\");\n\n  /**\n   * 获取当前时间\n   */\n  function get_time();\n\n  /**\n   * 通过1688平台找产品的采购货源。可用于分析产品的采购成本价\n   *\n   * @param searchName 查询的产品名称\n   */\n  function ali1688_similar_product(searchName: string);\n\n  /**\n   * 查询亚马逊电商平台上热搜关键词的延伸词关键词，可用于卖家查询相关关键词、发现长尾词或挖掘个性化需求\n   *\n   * @param keyword 查询的关键词\n   * @param page? 查询结果的页码索引，默认为第1页。每页返回20条数据\n   * @param keywordSupportSite? 亚马逊站点\n   */\n  function keyword_extends(keyword: string, page?: number, keywordSupportSite?: \"Unknow\" | \"US\" | \"GB\" | \"DE\" | \"FR\" | \"CA\" | \"JP\" | \"ES\" | \"IT\" | \"MX\" | \"AE\" | \"AU\" | \"BR\" | \"SA\");\n\n  /**\n   * 查询类目市场下的Best Seller产品，可用于类目数据分析\n   *\n   * @param nodeId 需要查找的类目Id\n   * @param page? 查询结果的页码索引，默认为第1页。每页返回20条数据\n   * @param site? Temu站点，支持：701:US, 705:EU\n   */\n  function temu_category_request(nodeId: string, page?: number, site?: \"UnKonw\" | \"US\" | \"EU\");\n\n  /**\n   * Shopee类目下Best Seller Top 500 产品，可用于类目数据分析\n   *\n   * @param nodeId 需要查找的类目Id\n   * @param queryDate? 选填，格式：yyyy-MM-dd，如果指定，用于查询历史（指定日期所处自然周）榜单数据。例如：2025-03-10。表示查询2025-03-10 ~\n   *                   2025-03-16 自然周的数据。注：仅细分类目支持历史回看，当非细分类目时此参数无效，始终返回当前类目下产品数据。\n   * @param page? 查询结果的页码索引，默认为第1页。每页返回20条数据\n   * @param site? Shopee站点，支持：201:VN，202:ID，203:SG，204:TH，205:MY，206:TW，207:PH，208:BR\n   */\n  function shopee_category_request(nodeId: string, queryDate?: string, page?: number, site?: \"UnKonw\" | \"VN\" | \"ID\" | \"SG\" | \"TH\" | \"MY\" | \"TW\" | \"PH\" | \"BR\");\n\n  /**\n   * 查询Temu产品详情\n   *\n   * @param productId 需要查询的产品Id\n   * @param site? Temu站点，支持：701:US, 705:EU\n   */\n  function temu_product_request(productId: string, site?: \"UnKonw\" | \"US\" | \"EU\");\n\n  /**\n   * 查询沃尔玛电商平台上产品的详情数据\n   *\n   * @param productId 产品ID，仅支持单产品ID查询\n   */\n  function walmart_product_detail_by_product_id(productId: string);\n\n  /**\n   * 搜索Temu电商平台上的产品数据，支持多维度筛选，按月销量倒序排列。\n   *\n   * @param productId? 选填，如果指定：基于ProductId查询同类产品\n   *                   示例：B0CVM8TXHP\n   * @param nodeId? 选填，如果指定：限定搜索范围为指定类目和其下级类目。（指定的类目nodeId不限为细分类目）\n   *                示例：3743561\n   * @param brand? 选填，如果指定：查询品牌热销产品\n   *               示例：Anker\n   * @param sellerName? 选填，如果指定：基于卖家名称查询热销产品\n   *                    示例：AnkerDirect\n   * @param cumulativeSaleCountMin? 选填，如果指定：限定累计销量最小值（val >= 设定值）查产品\n   *                                示例：1000\n   * @param cumulativeSaleCountMax? 选填，如果指定：限定累计销量最大值（val <= 设定值）查产品\n   *                                示例：100000\n   * @param saleCountMin? 选填，如果指定：限定月销量最小值（val >= 设定值）查产品\n   *                      示例：100\n   * @param saleCountMax? 选填，如果指定：限定月销量最大值（val <= 设定值）查产品\n   *                      示例：50000\n   * @param saleAmountMin? 选填，如果指定：限定月销额最小值（val >= 设定值）查产品\n   *                       示例：1000.00\n   * @param saleAmountMax? 选填，如果指定：限定月销额最大值（val <= 设定值）查产品\n   *                       示例：500000.00\n   * @param saleCountMomMin? 选填，如果指定：限定月销量环比最小值（val >= 设定值）查产品，单位：%\n   *                         示例：20，代表20%\n   * @param saleCountMomMax? 选填，如果指定：限定月销量环比最大值（val <= 设定值）查产品，单位：%\n   *                         示例：20，代表20%\n   * @param priceMin? 选填，如果指定：限定销售价最小值（val >= 设定值）查产品\n   *                  示例：5\n   * @param priceMax? 选填，如果指定：限定销售价最大值（val <= 设定值）查产品\n   *                  示例：10\n   * @param manageType? 选填，如果指定：基于托管类型查产品\n   *                    可选值：0=全部 1=半托管，2=全托管\n   *                    示例：0\n   * @param commentCountMin? 选填，如果指定：限定评论数最小值（val >= 设定值）查产品\n   *                         示例：10\n   * @param commentCountMax? 选填，如果指定：限定评论数最大值（val <= 设定值）查产品\n   *                         示例：5000\n   * @param starMin? 选填，如果指定：限定星级最小值（val >= 设定值）查产品\n   *                 示例：4.0\n   * @param starMax? 选填，如果指定：限定星级最大值（val <= 设定值）查产品\n   *                 示例：4.9\n   * @param saleTimeMin? 选填，如果指定：限定产品上架时间起始时间查产品，日期格式为yyyy-MM-dd\n   *                     示例：2025-01-01\n   * @param saleTimeMax? 选填，如果指定：限定产品上架时间截止时间查产品，日期格式为yyyy-MM-dd\n   *                     示例：2026-01-01\n   * @param site? Temu站点，支持：701:US, 705:EU\n   * @param page? 分页查询，每页最多20个产品。默认为1，表示第1页 （全部结果分页从1开始，而非0）\n   *              示例：1\n   */\n  function temu_product_search(productId?: string, nodeId?: string, brand?: string, sellerName?: string, cumulativeSaleCountMin?: number);\n  // optional (18): cumulativeSaleCountMax, saleCountMin, saleCountMax, saleAmountMin, saleAmountMax, ...\n\n  /**\n   * 在我的亚马逊平台关键词词库中添加关键词收藏\n   *\n   * @param keyword 需要收藏的词\n   * @param dict? 选填，如果指定，将添加词到指定收藏夹\n   * @param keywordSupportSite? 亚马逊站点\n  