} | 均价: {d[\\\"平均价格\\\"]} | 中位数: {d[\\\"中位数价格\\\"]} | 月增长: {d[\\\"月销量环比\\\"]}% | 月销: {d[\\\"月销量\\\"]}')\nprint('='*80)\ntop50 = d.get('Top50产品', [])\n\n# 按价格降序排\ndef get_price(p):\n    try: return float(re.sub(r'[^\\d.]', '', str(p.get('价格','0'))))\n    except: return 0\n    \n# 按增长率排（正增长优先）\npositive = [p for p in top50 if p.get('周销量环比', 0) > 0]\nnegative = [p for p in top50 if p.get('周销量环比', 0) <= 0]\n\nprint(f'=== 正增长产品 ({len(positive)}个) ===')\nsorted_pos = sorted(positive, key=lambda p: (get_price(p), p.get('周销量环比',0)), reverse=True)\nfor i, p in enumerate(sorted_pos[:20], 1):\n    price = p.get('价格','N/A')\n    title = p.get('标题','N/A')[:55]\n    sales = p.get('月销量', 0)\n    stars = p.get('星级','N/A')\n    growth = p.get('周销量环比', 0)\n    print(f'{i:2d}. {price:>8s} | 月销{sales:>6d} | ⭐{stars} | 增长+{growth:>5.1f}% | {title}')\n\nprint(f'')\nprint(f'=== 高价产品 TOP10 (价格降序) ===')\nsorted_price = sorted(top50, key=get_price, reverse=True)\nfor i, p in enumerate(sorted_price[:10], 1):\n    price = p.get('价格','N/A')\n    title = p.get('标题','N/A')[:55]\n    sales = p.get('月销量', 0)\n    stars = p.get('星级','N/A')\n    growth = p.get('周销量环比', 0)\n    print(f'{i:2d}. {price:>8s} | 月销{sales:>6d} | ⭐{stars} | 增长{growth:>7.1f}% | {title}')\n\""}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":6823,"output":1079,"cacheRead":119873,"cacheWrite":0,"totalTokens":127775,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1780647146817,"responseId":"0671b7eb6e3ee781f838833ed24fa3ec"}}
