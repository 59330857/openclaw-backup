asoning override is set.\",\n          \"tags\": [\n            \"advanced\"\n          ]\n        },\n        \"hintPath\": \"agents.list[].reasoningDefault\"\n      },\n      {\n        \"key\": \"fastModeDefault\",\n        \"path\": \"agents.list.*.fastModeDefault\",\n        \"type\": \"boolean\",\n        \"required\": false,\n        \"hasChildren\": false,\n        \"reloadKind\": \"hot\",\n        \"hint\": {\n          \"label\": \"Agent Fast Mode Default\",\n          \"help\": \"Optional per-agent default for fast mode. Applies when no per-message or session fast-mode override is set.\",\n          \"tags\": [\n            \"advanced\"\n          ]\n        },\n        \"hintPath\": \"agents.list[].fastModeDefault\"\n      },\n      {\n        \"key\": \"contextInjection\",\n        \"path\": \"agents.list.*.contextInjection\",\n        \"required\": false,\n        \"hasChildren\": false,\n        \"reloadKind\": \"hot\",\n        \"hint\": {\n          \"label\": \"Agent Context Injection\",\n          \"help\": \"Per-agent override for when workspace bootstrap files are injected into this agent's system prompt. Omit to inherit agents.defaults.contextInjection.\",\n          \"tags\": [\n            \"advanced\"\n          ]\n        },\n        \"hintPath\": \"agents.list[].contextInjection\"\n      },\n      {\n        \"key\": \"bootstrapMaxChars\",\n        \"path\": \"agents.list.*.bootstrapMaxChars\",\n        \"type\": \"integer\",\n        \"required\": false,\n        \"hasChildren\": false,\n        \"reloadKind\": \"hot\",\n        \"hint\": {\n          \"label\": \"Agent Bootstrap Max Chars\",\n          \"help\": \"Per-agent override for max characters of each workspace bootstrap file injected into this agent's system prompt. Omit to inherit agents.defaults.bootstrapMaxChars.\",\n          \"tags\": [\n            \"performance\"\n          ]\n        },\n        \"hintPath\": \"agents.list[].bootstrapMaxChars\"\n      },\n      {\n        \"key\": \"bootstrapTotalMaxChars\",\n        \"path\": \"agents.list.*.bootstrapTotalMaxChars\",\n        \"type\": \"integer\",\n        \"required\": false,\n        \"hasChildren\": false,\n        \"reloadKind\": \"hot\",\n        \"hint\": {\n          \"label\": \"Agent Bootstrap Total Max Chars\",\n          \"help\": \"Per-agent override for max total characters across all workspace bootstrap files injected into this agent's system prompt. Omit to inherit agents.defaults.bootstrapTotalMaxChars.\",\n          \"tags\": [\n            \"performance\"\n          ]\n        },\n        \"hintPath\": \"agents.list[].bootstrapTotalMaxChars\"\n      },\n      {\n        \"key\": \"experimental\",\n        \"path\": \"agents.list.*.experimental\",\n        \"type\": \"object\",\n        \"required\": false,\n        \"hasChildren\": true,\n        \"reloadKind\": \"hot\",\n        \"hint\": {\n          \"label\": \"Agent Experimental Flags\",\n          \"help\": \"Per-agent experimental flags. Omitted fields inherit agents.defaults.experimental.\",\n          \"tags\": [\n            \"security\",\n            \"advanced\"\n          ]\n        },\n        \"hintPath\": \"agents.list[].experimental\"\n      },\n      {\n        \"key\": \"skills\",\n        \"path\": \"agents.list.*.skills\",\n        \"type\": \"array\",\n        \"required\": false,\n        \"hasChildren\": true,\n        \"reloadKind\": \"hot\",\n        \"hint\": {\n          \"label\": \"Agent Skill Filter\",\n          \"help\": \"Optional allowlist of skills for this agent. If omitted, the agent inherits agents.defaults.skills when set; otherwise skills stay unrestricted. Set [] for no skills. An explicit list fully replaces inherited defaults instead of merging with them.\",\n          \"tags\": [\n            \"advanced\"\n          ]\n        },\n        \"hintPath\": \"agents.list.*.skills\"\n      },\n      {\n        \"key\": \"memorySearch\",\n        \"path\": \"agents.list.*.me