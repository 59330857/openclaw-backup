{"type":"message","id":"72d74fb8","parentId":"d2f4ba5e","timestamp":"2026-06-03T02:51:26.731Z","message":{"role":"toolResult","toolCallId":"call_function_pfmncr6pg1ye_2","toolName":"exec","content":[{"type":"text","text":"error: unknown option '--dry-run'\n\nUsage: clawhub update [options] [slug]\n\nUpdate installed skills\n\nArguments:\n  slug                 Skill slug\n\nOptions:\n  --all                Update all installed skills\n  --version <version>  Update to specific version (single slug only)\n  --force              Overwrite when local files do not match any version\n  -h, --help           display help for command"}],"details":{"status":"completed","exitCode":0,"durationMs":821,"aggregated":"error: unknown option '--dry-run'\n\nUsage: clawhub update [options] [slug]\n\nUpdate installed skills\n\nArguments:\n  slug                 Skill slug\n\nOptions:\n  --all                Update all installed skills\n  --version <version>  Update to specific version (single slug only)\n  --force              Overwrite when local files do not match any version\n  -h, --help           display help for command","cwd":"/home/halei/.openclaw/workspace"},"isError":false,"timestamp":1780455086729}}
