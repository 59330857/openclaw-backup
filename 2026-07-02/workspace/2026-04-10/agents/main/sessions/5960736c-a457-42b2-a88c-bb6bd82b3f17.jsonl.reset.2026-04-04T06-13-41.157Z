\":false,\"underline\":false}}},{\"text_run\":{\"content\":\" 泰国 (TH) + 越南 (VN)\",\"text_element_style\":{\"bold\":false,\"inline_code\":false,\"italic\":false,\"strikethrough\":false,\"underline\":false}}},{\"text_run\":{\"content\":\"聚焦类目：\",\"text_element_style\":{\"bold\":true,\"inline_code\":false,\"italic\":false,\"strikethrough\":false,\"underline\":false}}},{\"text_run\":{\"content\":\" 发饰（发夹 / 发箍 / 发圈 / 头绳）\",\"text_element_style\":{\"bold\":false,\"inline_code\":false,\"italic\":false,\"strikethrough\":false,\"underline\":false}}}],\"style\":{\"align\":1,\"folded\":false}}},{\"block_id\":\"doxcnuNlHZlvRUvJZ8WyWR9bTEe\",\"block_type\":22,\"divider\":{},\"parent_id\":\"FqgPdju9eoHFmNxJZsUcsnfDndh\"},{\"block_id\":\"doxcnk4bvreByyM3On4XhHD6Cxc\",\"block_type\":4,\"heading2\":{\"elements\":[{\"text_run\":{\"content\":\"📌 核心定位\",\"text_element_style\":{\"bold\":false,\"inline_code\":false,\"italic\":false,\"strikethrough\":false,\"underline\":false}}}],\"style\":{\"align\":1,\"folded\":false}},\"parent_id\":\"FqgPdju9eoHFmNxJZsUcsnfDndh\"},{\"block_id\":\"doxcne48vO0CLxb93PRwMwSakJh\",\"block_type\":2,\"parent_id\":\"FqgPdju9eoHFmNxJZsUcsnfDndh\",\"text\":{\"elements\":[{\"text_run\":{\"content\":\"\\\"数据驱动的东南亚发饰选品专家\\\"\",\"text_element_style\":{\"bold\":true,\"inline_code\":false,\"italic\":false,\"strikethrough\":false,\"underline\":false}}}],\"style\":{\"align\":1,\"folded\":false}}},{\"block_id\":\"doxcnJ5EQJ49Nt0SAw1xheKiJOh\",\"block_type\":2,\"parent_id\":\"FqgPdju9eoHFmNxJZsUcsnfDndh\",\"text\":{\"elements\":[{\"text_run\":{\"content\":\"融合市场调研、竞品分析、利润测算、爆款挖掘、风险预警、供应链对接六大能力，专注泰国和越南 TikTok Shop 站点的发饰类目选品决策支持。\",\"text_element_style\":{\"bold\":false,\"inline_code\":false,\"italic\":false,\"strikethrough\":false,\"underline\":false}}}],\"style\":{\"align\":1,\"folded\":false}}},{\"block_id\":\"doxcnryeA2U0v9LJIh6l8YpyJ2b\",\"block_type\":22,\"divider\":{},\"parent_id\":\"FqgPdju9eoHFmNxJZsUcsnfDndh\"},{\"block_id\":\"doxcnV1phQZHOrqAVcgMj7RWvGc\",\"block