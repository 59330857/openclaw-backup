":false,\"italic\":false,\"strikethrough\":false,\"underline\":false}}}],\"style\":{\"align\":1,\"folded\":false}}},{\"block_id\":\"doxcnSxuhYs8WfrHwe4uLWNavmf\",\"block_type\":14,\"code\":{\"elements\":[{\"text_run\":{\"content\":\"# 发饰选品报告 - [泰国/越南] - [日期]\\n\\n## 📈 执行摘要\\n- 扫描总数 / 符合条件 / 推荐分布\\n\\n## 🌏 市场概览\\n- 热销榜 TOP 10 分析\\n- 流行趋势（颜色/材质/风格）\\n\\n## 🏆 潜力爆款推荐（TOP 5-10）\\n### 商品 #1：[名称] ⭐⭐⭐⭐⭐ S 级\\n**推荐理由：** 增长率、竞争度、利润率\\n**利润测算：** 成本、售价、利润空间\\n**行动建议：** 首单量、定价、活动搭配\\n**风险提示：** 具体风险点\\n\\n## ⚠️ 风险提醒\\n- 高风险 IP 列表\\n- 材质合规注意事项\\n- 平台新规解读\\n\\n## 📦 供应链推荐\\n- 优质供应商 TOP 3\\n\\n## 🎯 下周行动计划\\n1. 优先采购清单\\n2. 重点关注趋势\\n3. 避免踩坑点\\n\",\"text_element_style\":{\"bold\":false,\"inline_code\":false,\"italic\":false,\"strikethrough\":false,\"underline\":false}}}],\"style\":{\"language\":39,\"wrap\":false}},\"parent_id\":\"FqgPdju9eoHFmNxJZsUcsnfDndh\"},{\"block_id\":\"doxcnDdm5ovSsMakVI1NA3uvlTb\",\"block_type\":22,\"divider\":{},\"parent_id\":\"FqgPdju9eoHFmNxJZsUcsnfDndh\"},{\"block_id\":\"doxcnp6NnW2QcmgFI5IvVLBNZue\",\"block_type\":4,\"heading2\":{\"elements\":[{\"text_run\":{\"content\":\"🚨 风险控制\",\"text_element_style\":{\"bold\":false,\"inline_code\":false,\"italic\":false,\"strikethrough\":false,\"underline\":false}}}],\"style\":{\"align\":1,\"folded\":false}},\"parent_id\":\"FqgPdju9eoHFmNxJZsUcsnfDndh\"},{\"block_id\":\"doxcnL5st4R61WeMcAMvYmTPiAh\",\"block_type\":5,\"heading3\":{\"elements\":[{\"text_run\":{\"content\":\"IP 侵权黑名单（发饰高危区）\",\"text_element_style\":{\"bold\":false,\"inline_code\":false,\"italic\":false,\"strikethrough\":false,\"underline\":false}}}],\"style\":{\"align\":1,\"folded\":false}},\"parent_id\":\"FqgPdju9eoHFmNxJZsUcsnfDndh\"},{\"block_id\":\"doxcnWRULSxUqhoFz22d33A1Rkc\",\"block_type\":14,\"code\":{\"elements\":[{\"text_run\":{\"content\":\"❌ Disney：米奇、冰雪奇缘、公主系列\\n❌ Sanrio：Hello Kitty、美乐蒂、库洛米\\n❌ Line Friends：布朗熊、莎莉鸡\\n❌ 动漫 IP：火影、海贼王、鬼灭之刃\\n❌ 奢侈品：Dior、Chanel、Gucci（logo/经典元素）\\n\",\"text_element_style\":{\"bold\":false,\"inline_code\":false,\"italic\":false,\"strikethrough\":false,\"underline\":false}}}],\"style\":{\"language\":1,\"wrap\":false}},\"parent_id\":\"FqgPdju9eoHFmNxJZsUcsnfDndh\"},{\"block_id\":\"doxcnfHEV5xbu3ZbRBCTuzj4xhf\",\"block_type\":2,\"parent_id\":\"FqgPdju9eoHFmNxJZsUcsnfDndh\",\"text\":{\"elements\":[{\"text_run\":{\"content\":\"处理原则：\",\"text_element_style\":{\"bold\":true,\"inline_code\":false,\"italic\":false,\"strikethrough\":false,\"underline\":false}}},{\"text_run\":{\"content\":\" 宁可错杀，不可放过；擦边球一律不碰\",\"text_element_style\":{\"bold\":false,\"inline_code\":false,\"italic\":false,\"strikethrough\":false,\"underline\":false}}}],\"style\":{\"align\":1,\"folded\":false}}},{\"block_id\":\"doxcnIQ1RsKA8d20zfxP5kZi2eh\",\"block_type\":22,\"divider\":{},\"parent_id\":\"FqgPdju9eoHFmNxJZsUcsnfDndh\"},{\"block_id\":\"doxcn9AGNzsB6JayyVtf63W1ige\",\"block_type\":5,\"heading3\":{\"elements\":[{\"text_run\":{\"content\":\"材质合规要求\",\"text_element_style\":{\"bold\":false,\"inline_code\":false,\"italic\":false,\"strikethrough\":false,\"underline\":false}}}],\"style\":{\"align\":1,\"folded\":false}},\"parent_id\":\"FqgPdju9eoHFmNxJZsUcsnfDndh\"},{\"block_id\":\"doxcnN91aBY9gbTTPxHw2Fpk0Vd\",\"block_type\":2,\"parent_id\":\"FqgPdju9eoHFmNxJZsUcsnfDndh\",\"text\":{\"elements\":[{\"text_run\":{\"content\":\"泰国：\",\"text_element_style\":{\"bold\":true,\"inline_code\":false,\"italic\":false,\"strikethrough\":false,\"underline\":false}}},{\"text_run\":{\"content\":\" 镍释放 \",\"text_element_style\":{\"bold\":false,\"inline_code\":false,\"italic\":false,\"strikethrough\":false,\"underline\":false}}},{\"text_run\":{\"content\":\"\\u003c 0.5μg/cm²/week，儿童发饰需玩具安全标准\",\"text_element_style\":{\"bold\":false,\"inline_code\":false,\"italic\":false,\"strikethrough\":false,\"underline\":false}}}],\"style\":{\"align\":1,\"folded\":false}}},{\"block_id\":\"doxcnMqKwmBgJ0gWRN3x0A3P3gg\",\"block_type\":2,\"parent_id\":\"FqgPdju9eoHFmNxJZsUcsnfDndh\",\"text\":{\"elements\":[{\"text_run\":{\"content\":\"越南：\",\"text_element_style\":{\"bold\":true,\"inline_code\":false,\"italic\":false,\"strikethrough\":false,\"underline\":false}}},{\"text_run\":{\"content\":\" 重金属限制，塑料需 ROHS 认证，进口需质检报告\",\"text_element_style\":{\"bold\":false,\"inline_code\":false,\"italic\":false,\"strikethrough\":false,\"underline\":false}}}],\"style\":{\"align\":1,\"folded\":false}}},{\"block_id\":\"doxcnMg0iRwbWZniVycsFF6s0Yb\",\"block_type\":2,\"parent_id\":\"FqgPdju9eoHFmNxJZsUcsnfDndh\",\"text\":{\"elements\":[{\"text_run\":{\"content\":\"建议：\",\"text_element_style\":{\"bold\":true,\"inline_code\":false,\"italic\":false,\"strikethrough\":false,\"underline\":false}}},{\"text_run\":{\"content\":\" 优先选择有质检报告的供应商，首单送检 SGS/TÜV\",\"text_element_style\":{\"bold\":false,\"inline_code\":false,\"italic\":false,\"strikethrough\":false,\"underline\":false}}}],\"style\":{\"align\":1,\"folded\":false}}},{\"block_id\":\"doxcncrD2ZjvnqRHzMN6bXD7Klc\",\"block_type\":22,\"divider\":{},\"parent_id\":\"FqgPdju9eoHFmNxJZsUcsnfDndh\"},{\"block_id\":\"doxcnK8NGiOaMFGbkQoCGJK4Vjb\",\"block_type\":5,\"heading3\":{\"elements\":[{\"text_run\":{\"content\":\"平台规则红线\",\"text_element_style\":{\"bold\":false,\"inline_code\":false,\"italic\":false,\"strikethrough\":false,\"underline\":false}}}],\"style\":{\"align\":1,\"folded\":false}},\"parent_id\":\"FqgPdju9eoHFmNxJZsUcsnfDndh\"},{\"block_id\":\"doxcnlFnVxykRLA3bxzuooLOHnc\",\"block_type\":12,\"bullet\":{\"elements\":[{\"text_run\":{\"content\":\"❌ 仿牌/假货 → 封店\",\"text_element_style\":{\"bold\":false,\"inline_code\":false,\"italic\":false,\"strikethrough\":false,\"underline\":false}}}],\"style\":{\"align\":1,\"folded\":false}},\"parent_id\":\"FqgPdju9eoHFmNxJZsUcsnfDndh\"},{\"block_id\":\"doxcnyyKX83tWt18TOJ5g2pcKIb\",\"block_type\":12,\"bullet\":{\"elements\":[{\"text_run\":{\"content\":\"❌ 侵权商品 → 下架 + 扣分\",\"text_element_style\":{\"bold\":false,\"inline_code\":false,\"italic\":false,\"strikethrough\":false,\"underline\":false}}}],\"style\":{\"align\":1,\"folded\":false}},\"parent_id\":