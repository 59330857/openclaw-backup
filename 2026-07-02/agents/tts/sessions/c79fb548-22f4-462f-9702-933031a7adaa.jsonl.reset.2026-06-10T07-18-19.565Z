\" | \"US\" | \"GB\" | \"DE\" | \"FR\" | \"IN\" | \"CA\" | \"JP\" | \"ES\" | \"IT\" | \"MX\" | \"AE\" | \"AU\" | \"BR\" | \"SA\");\n  function change_favorite_keyword(keyword: string, toDict: string, fromDict?: string, keywordSupportSite?: \"Unknow\" | \"US\" | \"GB\" | \"DE\" | \"FR\" | \"CA\" | \"JP\" | \"ES\" | \"IT\" | \"MX\" | \"AE\" | \"AU\" | \"BR\" | \"SA\");\n  function competitor_product_keywords(asin: string, page?: number, keywordSupportSite?: \"Unknow\" | \"US\" | \"GB\" | \"DE\" | \"FR\" | \"CA\" | \"JP\" | \"ES\" | \"IT\" | \"MX\" | \"AE\" | \"AU\" | \"BR\" | \"SA\");\n  function del_favorite_keyword(keyword: string, dict?: string, keywordSupportSite?: \"Unknow\" | \"US\" | \"GB\" | \"DE\" | \"FR\" | \"CA\" | \"JP\" | \"ES\" | \"IT\" | \"MX\" | \"AE\" | \"AU\" | \"BR\" | \"SA\");\n  function favorite_keyword(keyword: string, dict?: string, keywordSupportSite?: \"Unknow\" | \"US\" | \"GB\" | \"DE\" | \"FR\" | \"CA\" | \"JP\" | \"ES\" | \"IT\" | \"MX\" | \"AE\" | \"AU\" | \"BR\" | \"SA\");\n  function get_favorite_keyword_dict(page?: number, keywordSupportSite?: \"Unknow\" | \"US\" | \"GB\" | \"DE\" | \"FR\" | \"CA\" | \"JP\" | \"ES\" | \"IT\" | \"MX\" | \"AE\" | \"AU\" | \"BR\" | \"SA\");\n  function get_favorite_keyword(dict?: string, page?: number, keywordSupportSite?: \"Unknow\" | \"US\" | \"GB\" | \"DE\" | \"FR\" | \"CA\" | \"JP\" | \"ES\" | \"IT\" | \"MX\" | \"AE\" | \"AU\" | \"BR\" | \"SA\");\n  function get_time();\n  function keyword_detail(keyword: string, keywordSupportSite?: \"Unknow\" | \"US\" | \"GB\" | \"DE\" | \"FR\" | \"CA\" | \"JP\" | \"ES\" | \"IT\" | \"MX\" | \"AE\" | \"AU\" | \"BR\" | \"SA\");\n  function keyword_extends(keyword: string, page?: number, keywordSupportSite?: \"Unknow\" | \"US\" | \"GB\" | \"DE\" | \"FR\" | \"CA\" | \"JP\" | \"ES\" | \"IT\" | \"MX\" | \"AE\" | \"AU\" | \"BR\" | \"SA\");\n  function keyword_list_from_history(date: string, rank_min?: number, rank_max?: number, search_volume_min?: number, search_volume_ma