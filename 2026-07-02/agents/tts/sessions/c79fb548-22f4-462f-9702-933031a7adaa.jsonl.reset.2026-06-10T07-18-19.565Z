{"type":"message","id":"67b8c903","parentId":"a8e2fcdf","timestamp":"2026-06-09T00:58:38.365Z","message":{"role":"toolResult","toolCallId":"call_cf9f1924921e4a5bbe407c34","toolName":"exec","content":[{"type":"text","text":"sorftime-mcp\n\n  /**\n   * 查询我的Shopee平台关键词词库的词\n   *\n   * @param dict? 选填，如果指定，查询指定收藏夹下的词；如需查询全部词，指定传值`all`\n   * @param page? 查询结果的页码索引，默认为第1页。每页返回100条数据\n   * @param site? Shopee站点，支持：201:VN，202:ID，203:SG，204:TH，205:MY，206:TW，207:PH，208:BR\n   */\n  function shopee_get_favorite_keyword(dict?: string, page?: number, site?: \"UnKonw\" | \"VN\" | \"ID\" | \"SG\" | \"TH\" | \"MY\" | \"TW\" | \"PH\" | \"BR\");\n\n  /**\n   * 查询Tiktok平台产品详情\n   *\n   * @param productId 产品Id\n   * @param site? TikTok站点\n   */\n  function tiktok_product_detail(productId: string, site?: \"Unknow\" | \"US\" | \"MY\" | \"PH\" | \"VN\" | \"TH\" | \"ID\" | \"GB\" | \"JP\");\n\n  /**\n   * 搜索亚马逊电商平台上的潜力产品\n   *\n   * @param searchName? 可选参数，如果指定，将按此名称搜索相关产品\n   * @param price_min? 可选参数，如果指定表示筛选销售价大于等于此值的产品\n   * @param price_max? 可选参数，如果指定表示筛选销售价小于等于此值的产品\n   * @param month_sales_volume_min? 可选参数，如果指定表示筛选月销量大于等于此值的产品\n   * @param month_sales_volume_max? 可选参数，如果指定表示筛选月销量小于等于此值的产品\n   * @param delivery_type? 可选参数，如果指定，筛选产品的发货方式\n   * @param page? 查询结果的页码索引，默认为第1页。每页返回20条数据\n   * @param amzSite? 亚马逊站点\n   */\n  function potential_product(searchName?: string, price_min?: number, price_max?: number, month_sales_volume_min?: number, month_sales_volume_max?: number);\n  // optional (3): delivery_type, page, amzSite\n\n  /**\n   * 查询Tiktok平台产品趋势，同时返回`销量`，`价格`，`星级`，`评论数量`，`新增带货视频数`，`新增带货达人数`多个维度\n   *\n   * @param productId 产品Id\n   * @param site? TikTok站点\n   */\n  function tiktok_product_trend(productId: string, site?: \"Unknow\" | \"US\" | \"MY\" | \"PH\" | \"VN\" | \"TH\" | \"ID\" | \"GB\" | \"JP\");\n\n  /**\n   * 移动我的Shopee平台关键词词库中收藏的关键词到指定收藏夹，如果收藏夹不存在会新建\n   *\n   * @param keyword 需要移动的词\n   * @param toDict 移动到的收藏夹名称\n   * @param fromDict? 选填，如果指定，将移动指定收藏夹下的词\n   * @param site? Shopee站点，支持：201:VN，202:ID，203:SG，204:TH，205:MY，206:TW，207:PH，208:BR\n   */\n  function shopee_change_favorite_keyword(keyword: string, toDict: string, fromDict?: string, site?: \"UnKonw\" | \"VN\" | \"ID\" | \"SG\" | \"TH\" | \"MY\" | \"TW\" | \"PH\" | \"BR\");\n\n  /**\n   * 查询Shopee产品详情\n   *\n   * @param productId 需要查询的产品Id\n   * @param site? Shopee站点，支持：201:VN，202:ID，203:SG，204:TH，205:MY，206:TW，207:PH，208:BR\n   */\n  function shopee_product_request(productId: string, site?: \"UnKonw\" | \"VN\" | \"ID\" | \"SG\" | \"TH\" | \"MY\" | \"TW\" | \"PH\" | \"BR\");\n\n  /**\n   * 在我的Shopee平台关键词词库中添加关键词收藏\n   *\n   * @param keyword 需要收藏的词\n   * @param dict? 选填，如果指定，将添加词到指定收藏夹\n   * @param site? Shopee站点，支持：201:VN，202:ID，203:SG，204:TH，205:MY，206:TW，207:PH，208:BR\n   */\n  function shopee_favorite_keyword(keyword: string, dict?: string, site?: \"UnKonw\" | \"VN\" | \"ID\" | \"SG\" | \"TH\" | \"MY\" | \"TW\" | \"PH\" | \"BR\");\n\n  /**\n   * 查询亚马逊电商平台产品的子体明细\n   *\n   * @param asin 产品ASIN，仅支持单ASIN查询\n   * @param amzSite? 亚马逊站点\n   */\n  function product_variations(asin: string, amzSite?: \"Unknow\" | \"US\" | \"GB\" | \"DE\" | \"FR\" | \"IN\" | \"CA\" | \"JP\" | \"ES\" | \"IT\" | \"MX\" | \"AE\" | \"AU\" | \"BR\" | \"SA\");\n\n  /**\n   * 查询沃尔玛电商平台上热搜关键词近15日的搜索结果自然位产品清单\n   *\n   * @param keyword 查询的关键词\n   * @param page? 查询结果的页码索引，默认为第1页。每页返回20条数据\n   */\n  function walmart_keyword_search_results(keyword: string, page?: number);\n\n  /**\n   * 支持产品五大维度历史趋势：星级、评论数、价格、累计销量、近30日销量\n   *\n   * @param productId 需要查询的产品Id\n   * @param queryStart? 选填，查询趋势的时间段的开始时间，格式:yyyy-MM-dd。默认近1年。查询时间超过1年时，每次调用消耗变为10。\n   * @param queryEnd? 选填，查询趋势的时间段的结束时间，格式:yyyy-MM-dd。默认为当前时间。\n   * @param site? Shopee站点，支持：201:VN，202:ID，203:SG，204:TH，205:MY，206:TW，207:PH，208:BR\n   */\n  function shopee_product_trend(productId: string, queryStart?: string, queryEnd?: string, site?: \"UnKonw\" | \"VN\" | \"ID\" | \"SG\" | \"TH\" | \"MY\" | \"TW\" | \"PH\" | \"BR\");\n\n  /**\n   * 删除我的Shopee平台关键词词库中收藏的指定关键词\n   *\n   * @param keyword 需要删除的词\n   * @param dict? 选填，如果指定，将删除指定收藏夹下的词\n   * @param site? Shopee站点，支持：201:VN，202:ID，203:SG，204:TH，205:MY，206:TW，207:PH，208:BR\n   */\n  function shopee_del_favorite_keyword(keyword: string, dict?: string, site?: \"UnKonw\" | \"VN\" | \"ID\" | \"SG\" | \"TH\" | \"MY\" | \"TW\" | \"PH\" | \"BR\");\n\n  /**\n   * 查询Tiktok平台产品的带货达人\n   *\n   * @param productId 产品Id\n   * @param site? TikTok站点\n   */\n  function tiktok_product_video_author(productId: string, site?: \"Unknow\" | \"US\" | \"MY\" | \"PH\" | \"VN\" | \"TH\" | \"ID\" | \"GB\" | \"JP\");\n\n  /**\n   * 查询产品在Tiktok平台上的相似产品，可用于分析此类产品的销售情况\n   *\n   * @param searchName 查询的产品名称\n   * @param page? 查询结果的页码索引，默认为第1页。每页返回20条数据\n   * @param site? TikTok站点\n   */\n  function tiktok_similar_product(searchName: string, page?: number, site?: \"Unknow\" | \"US\" | \"MY\" | \"PH\" | \"VN\" | \"TH\" | \"ID\" | \"GB\" | \"JP\");\n\n  /**\n   * 查询Shopee卖家（店铺）详情\n   *\n   * @param shopId 需要查询的店铺Id\n   * @param site? Shopee站点，支持：201:VN，202:ID，203:SG，204:TH，205:MY，206:TW，207:PH，208:BR\n   */\n  function shopee_shop_request(shopId: string, site?: \"UnKonw\" | \"VN\" | \"ID\" | \"SG\" | \"TH\" | \"MY\" | \"TW\" | \"PH\" | \"BR\");\n\n  /**\n   * 搜索Shopee电商平台上的产品数据，支持多维度筛选，按月销量倒序排列\n   *\n   * @param asin? 选填，如果指定：基于ASIN查询同类产品（注意：并非只查询这个ASIN，如果需要这个产品请调用ProductRequest接口）\n   *              示例：B0CVM8TXHP\n   * @param nodeId? 选填，如果指定：基于类目查询（不限为细分类目）\n   *                示例：3743561\n   * @param priceRangeMin? 选填，如果指定：限定销售价最小值（val >= 设定值）查产品\n   *                       示例：20.00\n   * @param priceRangeMax? 选填，如果指定：限定销售价最大值（val <= 设定值）查产品\n   *                       示例：50.00\n   * @param monthSaleVolumeRangeMin? 选填，如果指定：限定月销量最小值（val >= 设定值）查产品\n   *                                 示例：500\n   * @param monthSaleVolumeRangeMax? 选填，如果指定：限定月销量最大值（val <= 设定值）查产品\n   *                                 示例：1000\n   * @param onlineDateRangeMin? 选填，如果指定：限定上架时间起始时间查产品，日期格式为yyyy-MM-dd\n   *                            示例：2025-01-01\n   * @param onlineDateRangeMax? 选填，如果指定：限定上架时间截止时间查产品，日期格式为yyyy-MM-dd\n   *                            示例：2026-01-01\n   * @param starRangeMin? 选填，如果指定：限定星级最小值查产品\n   *                      示例：4.0\n   * @param starRangeMax? 选填，如果指定：限定星级最大值查产品\n   *                      示例：4.8\n   * @param commentCountRangeMin? 选填，如果指定：限定评论数量最小值查产品\n   *                              示例：50\n   * @param commentCountRangeMax? 选填，如果指定：限定评论数量最大值查产品\n   *                              示例：500\n   * @param variationCountRangeMin? 选填，如果指定：限定子体数最小值查产品\n   *                                示例：1\n   * @param variationCountRangeMax? 选填，如果指定：限定子体数最大值查产品\n   *                                示例：10\n   * @param shopLocation? 选填，卖家来源：1：本土店，2：跨境店\n   * @param shopType? 选填，店铺类型：1：普通店，2：优选店，3：旗舰店\n   * @param site? Shopee站点，支持：201:VN，202:ID，203:SG，204:TH，205:MY，206:TW，207:PH，208:BR\n   * @param page? 分页查询，每页最多20个产品。默认为1，表示第1页 （全部结果分页从1开始，而非0）\n   *              示例：1\n   */\n  function shopee_product_search(asin?: string, nodeId?: string, priceRangeMin?: number, priceRangeMax?: number, monthSaleVolumeRangeMin?: number);\n  // optional (13): monthSaleVolumeRangeMax, onlineDateRangeMin, onlineDateRangeMax, starRangeMin, starRangeMax, ...\n\n  /**\n   * 查询亚马逊电商平台产品类目结构\n   *"}],"details":{"persistedDetailsTruncated":true,"originalDetailsBytesAtLeast":9850,"originalDetailKeys":["status","exitCode","durationMs","aggregated","cwd"],"status":"completed","cwd":"/home/halei/workspace-tts","exitCode":0},"isError":false,"timestamp":1780966718363}}
