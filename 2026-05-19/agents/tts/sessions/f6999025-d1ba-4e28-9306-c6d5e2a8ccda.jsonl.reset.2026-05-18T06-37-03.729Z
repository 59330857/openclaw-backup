ords?page_size=3\" \\\n  -H \"Authorization: Bearer ${TOKEN}\" 2>/dev/null | python3 -m json.tool 2>/dev/null | head -100"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":2651,"output":651,"cacheRead":62720,"cacheWrite":0,"totalTokens":66022,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1779025221806,"responseId":"0658f846865187ebde2704a33a81a35d"}}
