               \"color\": 0,\n                        \"id\": \"optvKTtuQP\",\n                        \"name\": \"Sorftime\\uff08\\u6570\\u636e\\u9a71\\u52a8\\uff09\"\n                    },\n                    {\n                        \"color\": 1,\n                        \"id\": \"optUcKuZhe\",\n                        \"name\": \"1688\\u76f4\\u9009\"\n                    },\n                    {\n                        \"color\": 2,\n                        \"id\": \"optSwI8CnX\",\n                        \"name\": \"\\u4e9a\\u9a6c\\u900a\\u7206\\u6b3e\\u8ddf\\u968f\"\n                    },\n                    {\n                        \"color\": 3,\n                        \"id\": \"optknpr1o3\",\n                        \"name\": \"TikTok\\u7206\\u6b3e\\u8ddf\\u968f\"\n                    }\n                ]\n            },\n            \"type\": 4,\n            \"ui_type\": \"MultiSelect\"\n        }\n    },\n    \"msg\": \"success\"\n}","cwd":"/home/halei/workspace-tts"},"isError":false,"timestamp":1779026481976}}
