{"type":"message","id":"c6b52e9b","parentId":"c1e8b6fd","timestamp":"2026-05-17T13:31:06.467Z","message":{"role":"toolResult","toolCallId":"call_function_m4xivc7vetix_1","toolName":"exec","content":[{"type":"text","text":"sorftime-test\n\n  /**\n   * 查询Tiktok电商平台**指定类目**的类目数据报告\n   *\n   * @param nodeId 类目市场nodeid，可通过TiktokCategoryNameSearch获得\n   * @param site? TikTok站点\n   */\n  function tiktok_category_report(nodeId: string, site?: \"Unknow\" | \"US\" | \"MY\" | \"PH\" | \"VN\" | \"ID\" | \"GB\");\n      {\n        \"type\": \"object\",\n        \"properties\": {\n          \"nodeId\": {\n            \"description\": \"类目市场nodeid，可通过TiktokCategoryNameSearch获得\",\n            \"type\": \"string\"\n          },\n          \"site\": {\n            \"description\": \"TikTok站点\",\n            \"type\": \"string\",\n            \"enum\": [\n              \"Unknow\",\n              \"US\",\n              \"MY\",\n              \"PH\",\n              \"VN\",\n              \"ID\",\n              \"GB\"\n            ],\n            \"default\": \"Unknow\"\n          }\n        },\n        \"required\": [\n          \"nodeId\"\n        ]\n      }\n\n  /**\n   * 查询亚马逊平台上类目产品的特点\n   *\n   * @param productName 查询的类目名称\n   * @param amzSite? 亚马逊站点\n   */\n  function similar_product_feature(productName: string, amzSite?: \"Unknow\" | \"US\" | \"GB\" | \"DE\" | \"FR\" | \"IN\" | \"CA\" | \"JP\" | \"ES\" | \"IT\" | \"MX\" | \"AE\" | \"AU\" | \"BR\" | \"SA\");\n      {\n        \"type\": \"object\",\n        \"properties\": {\n          \"productName\": {\n            \"description\": \"查询的类目名称\",\n            \"type\": \"string\"\n          },\n          \"amzSite\": {\n            \"description\": \"亚马逊站点\",\n            \"type\": \"string\",\n            \"enum\": [\n              \"Unknow\",\n              \"US\",\n              \"GB\",\n              \"DE\",\n              \"FR\",\n              \"IN\",\n              \"CA\",\n              \"JP\",\n              \"ES\",\n              \"IT\",\n              \"MX\",\n              \"AE\",\n              \"AU\",\n              \"BR\",\n              \"SA\"\n            ],\n            \"default\": \"Unknow\"\n          }\n        },\n        \"required\": [\n          \"productName\"\n        ]\n      }\n\n  /**\n   * 查询沃尔玛电商平台上实时热搜关键词榜，按月搜索量排序\n   *\n   * @param rank_min 排名范围起始值（如：1）\n   * @param rank_max 排名范围结束值（如：100）\n   * @param page? 查询结果的页码索引，默认为第1页。每页返回20条数据\n   */\n  function walmart_keyword_list(rank_min: number, rank_max: number, page?: number);\n      {\n        \"type\": \"object\",\n        \"properties\": {\n          \"rank_min\": {\n            \"description\": \"排名范围起始值（如：1）\",\n            \"type\": \"integer\"\n          },\n          \"rank_max\": {\n            \"description\": \"排名范围结束值（如：100）\",\n            \"type\": \"integer\"\n          },\n          \"page\": {\n            \"description\": \"查询结果的页码索引，默认为第1页。每页返回20条数据\",\n            \"type\": \"integer\","}],"details":{"status":"completed","exitCode":0,"durationMs":1785,"aggregated":"sorftime-test\n\n  /**\n   * 查询Tiktok电商平台**指定类目**的类目数据报告\n   *\n   * @param nodeId 类目市场nodeid，可通过TiktokCategoryNameSearch获得\n   * @param site? TikTok站点\n   */\n  function tiktok_category_report(nodeId: string, site?: \"Unknow\" | \"US\" | \"MY\" | \"PH\" | \"VN\" | \"ID\" | \"GB\");\n      {\n        \"type\": \"object\",\n        \"properties\": {\n          \"nodeId\": {\n            \"description\": \"类目市场nodeid，可通过TiktokCategoryNameSearch获得\",\n            \"type\": \"string\"\n          },\n          \"site\": {\n            \"description\": \"TikTok站点\",\n            \"type\": \"string\",\n            \"enum\": [\n              \"Unknow\",\n              \"US\",\n              \"MY\",\n              \"PH\",\n              \"VN\",\n              \"ID\",\n              \"GB\"\n            ],\n            \"default\": \"Unknow\"\n          }\n        },\n        \"required\": [\n          \"nodeId\"\n        ]\n      }\n\n  /**\n   * 查询亚马逊平台上类目产品的特点\n   *\n   * @param productName 查询的类目名称\n   * @param amzSite? 亚马逊站点\n   */\n  function similar_product_feature(productName: string, amzSite?: \"Unknow\" | \"US\" | \"GB\" | \"DE\" | \"FR\" | \"IN\" | \"CA\" | \"JP\" | \"ES\" | \"IT\" | \"MX\" | \"AE\" | \"AU\" | \"BR\" | \"SA\");\n      {\n        \"type\": \"object\",\n        \"properties\": {\n          \"productName\": {\n            \"description\": \"查询的类目名称\",\n            \"type\": \"string\"\n          },\n          \"amzSite\": {\n            \"description\": \"亚马逊站点\",\n            \"type\": \"string\",\n            \"enum\": [\n              \"Unknow\",\n              \"US\",\n              \"GB\",\n              \"DE\",\n              \"FR\",\n              \"IN\",\n              \"CA\",\n              \"JP\",\n              \"ES\",\n              \"IT\",\n              \"MX\",\n              \"AE\",\n              \"AU\",\n              \"BR\",\n              \"SA\"\n            ],\n            \"default\": \"Unknow\"\n          }\n        },\n        \"required\": [\n          \"productName\"\n        ]\n      }\n\n  /**\n   * 查询沃尔玛电商平台上实时热搜关键词榜，按月搜索量排序\n   *\n   * @param rank_min 排名范围起始值（如：1）\n   * @param rank_max 排名范围结束值（如：100）\n   * @param page? 查询结果的页码索引，默认为第1页。每页返回20条数据\n   */\n  function walmart_keyword_list(rank_min: number, rank_max: number, page?: number);\n      {\n        \"type\": \"object\",\n        \"properties\": {\n          \"rank_min\": {\n            \"description\": \"排名范围起始值（如：1）\",\n            \"type\": \"integer\"\n          },\n          \"rank_max\": {\n            \"description\": \"排名范围结束值（如：100）\",\n            \"type\": \"integer\"\n          },\n          \"page\": {\n            \"description\": \"查询结果的页码索引，默认为第1页。每页返回20条数据\",\n            \"type\": \"integer\",","cwd":"/home/halei/workspace-tts"},"isError":false,"timestamp":1779024666466}}
