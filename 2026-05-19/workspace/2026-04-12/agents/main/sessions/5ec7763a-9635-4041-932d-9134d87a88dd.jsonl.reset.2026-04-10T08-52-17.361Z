{"type":"message","id":"683bb683","parentId":"b9ecb9e5","timestamp":"2026-04-10T01:30:20.334Z","message":{"role":"toolResult","toolCallId":"call_function_7110kzgjfvmg_1","toolName":"exec","content":[{"type":"text","text":"#!/bin/bash\n# OpenClaw 全量备份脚本 v2\n# 备份到 GitHub（增量），添加日期标签\n\nset -e\n\nREPO_DIR=\"/tmp/openclaw-backup-git\"\nSOURCE_OPENCLAW=\"$HOME/.openclaw\"\nSOURCE_OPENVIKING=\"$HOME/.openviking\"\nREPO=\"https://github.com/59330857/openclaw-backup.git\"\nTODAY=$(date +%Y-%m-%d)\n\n# 克隆或更新仓库\nif [ -d \"$REPO_DIR/.git\" ]; then\n    cd \"$REPO_DIR\"\n    git pull --quiet origin main\nelse\n    rm -rf \"$REPO_DIR\"\n    git clone --depth 1 \"$REPO\" \"$REPO_DIR\"\n    cd \"$REPO_DIR\"\nfi\n\n# 同步 OpenClaw 配置文件（脱敏）\nrsync -av --quiet \\\n    --exclude='credentials' \\\n    --exclude='logs' \\\n    --exclude='extensions' \\\n    --exclude='subagents' \\\n    --exclude='tasks/runs.sqlite' \\\n    \"$SOURCE_OPENCLAW/openclaw.json\" ./\n\n# 脱敏 openclaw.json\nif [ -f openclaw.json ]; then\n    python3 -c \"\nimport json\nwith open('openclaw.json') as f:\n    d = json.load(f)\ndef mask(obj):\n    if isinstance(obj, dict):\n        for k in obj:\n            if k in ('token', 'apiKey', 'password', 'secret', 'socketToken'):\n                obj[k] = '***REDACTED***'\n            else:\n                mask(obj[k])\n    elif isinstance(obj, list):\n        for i in obj:\n            mask(i)\nmask(d)\nwith open('openclaw.json', 'w') as f:\n    json.dump(d, f, indent=2)\n\" 2>/dev/null || true\nfi\n\n# 同步 workspace（含记忆、skills、agents、cron、identity）\nrsync -av --quiet \\\n    --exclude='.git' \\\n    \"$SOURCE_OPENCLAW/workspace/\" \"./workspace/\"\n\nrsync -av --quiet \\\n    --exclude='.git' \\\n    \"$SOURCE_OPENCLAW/workspace-main/\" \"./workspace-main/\" 2>/dev/null || true\n\nrsync -av --quiet \\\n    --exclude='.git' \\\n    \"$SOURCE_OPENCLAW/workspace-selector/\" \"./workspace-selector/\" 2>/dev/null || true\n\nrsync -av --quiet \\\n    --exclude='*.db' \\\n    --exclude='*.db-shm' \\\n    --exclude='*.db-wal' \\\n    \"$SOURCE_OPENCLAW/agents/\" \"./agents/\"\n\nrsync -av --quiet \\\n    \"$SOURCE_OPENCLAW/cron/\" \"./cron/\" 2>/dev/null || true\n\nrsync -av --quiet \\\n    \"$SOURCE_OPENCLAW/identity/\" \"./identity/\" 2>/dev/null || true\n\nrsync -av --quiet \\\n    --exclude='*.db' \\\n    --exclude='*.db-shm' \\\n    --exclude='*.db-wal' \\\n    \"$SOURCE_OPENCLAW/flows/\" \"./flows/\" 2>/dev/null || true\n\nrsync -av --quiet \\\n    \"$SOURCE_OPENCLAW/devices/\" \"./devices/\" 2>/dev/null || true\n\nrsync -av --quiet \\\n    \"$SOURCE_OPENCLAW/delivery-queue/\" \"./delivery-queue/\" 2>/dev/null || true\n\nrsync -av --quiet \\\n    --exclude='memory/lancedb-pro' \\\n    \"$SOURCE_OPENCLAW/memory/\" \"./memory/\" 2>/dev/null || true\n\n# 同步 skills\nrsync -av --quiet \\\n    --exclude='node_modules' \\\n    \"$SOURCE_OPENCLAW/skills/\" \"./skills/\" 2>/dev/null || true\n\n# 同步 OpenViking 关键数据（不含 _system 和 bot）\nrsync -av --quiet \\\n    --exclude='_system' \\\n    --exclude='bot' \\\n    --exclude='.openviking.pid' \\\n    \"$SOURCE_OPENVIKING/\" \"./openviking/\"\n\n# 提交\ngit add -A\nif git diff --cached --quiet; then\n    echo \"[$TODAY] No changes\"\nelse\n    git commit -m \"Full backup $TODAY\"\n    git push --quiet origin main\n    git tag -a \"backup-$TODAY\" -m \"Full backup $TODAY\"\n    git push origin \"backup-$TODAY\" --quiet\n    echo \"[$TODAY] Backup complete\"\nfi"}],"details":{"status":"completed","exitCode":0,"durationMs":55,"aggregated":"#!/bin/bash\n# OpenClaw 全量备份脚本 v2\n# 备份到 GitHub（增量），添加日期标签\n\nset -e\n\nREPO_DIR=\"/tmp/openclaw-backup-git\"\nSOURCE_OPENCLAW=\"$HOME/.openclaw\"\nSOURCE_OPENVIKING=\"$HOME/.openviking\"\nREPO=\"https://github.com/59330857/openclaw-backup.git\"\nTODAY=$(date +%Y-%m-%d)\n\n# 克隆或更新仓库\nif [ -d \"$REPO_DIR/.git\" ]; then\n    cd \"$REPO_DIR\"\n    git pull --quiet origin main\nelse\n    rm -rf \"$REPO_DIR\"\n    git clone --depth 1 \"$REPO\" \"$REPO_DIR\"\n    cd \"$REPO_DIR\"\nfi\n\n# 同步 OpenClaw 配置文件（脱敏）\nrsync -av --quiet \\\n    --exclude='credentials' \\\n    --exclude='logs' \\\n    --exclude='extensions' \\\n    --exclude='subagents' \\\n    --exclude='tasks/runs.sqlite' \\\n    \"$SOURCE_OPENCLAW/openclaw.json\" ./\n\n# 脱敏 openclaw.json\nif [ -f openclaw.json ]; then\n    python3 -c \"\nimport json\nwith open('openclaw.json') as f:\n    d = json.load(f)\ndef mask(obj):\n    if isinstance(obj, dict):\n        for k in obj:\n            if k in ('token', 'apiKey', 'password', 'secret', 'socketToken'):\n                obj[k] = '***REDACTED***'\n            else:\n                mask(obj[k])\n    elif isinstance(obj, list):\n        for i in obj:\n            mask(i)\nmask(d)\nwith open('openclaw.json', 'w') as f:\n    json.dump(d, f, indent=2)\n\" 2>/dev/null || true\nfi\n\n# 同步 workspace（含记忆、skills、agents、cron、identity）\nrsync -av --quiet \\\n    --exclude='.git' \\\n    \"$SOURCE_OPENCLAW/workspace/\" \"./workspace/\"\n\nrsync -av --quiet \\\n    --exclude='.git' \\\n    \"$SOURCE_OPENCLAW/workspace-main/\" \"./workspace-main/\" 2>/dev/null || true\n\nrsync -av --quiet \\\n    --exclude='.git' \\\n    \"$SOURCE_OPENCLAW/workspace-selector/\" \"./workspace-selector/\" 2>/dev/null || true\n\nrsync -av --quiet \\\n    --exclude='*.db' \\\n    --exclude='*.db-shm' \\\n    --exclude='*.db-wal' \\\n    \"$SOURCE_OPENCLAW/agents/\" \"./agents/\"\n\nrsync -av --quiet \\\n    \"$SOURCE_OPENCLAW/cron/\" \"./cron/\" 2>/dev/null || true\n\nrsync -av --quiet \\\n    \"$SOURCE_OPENCLAW/identity/\" \"./identity/\" 2>/dev/null || true\n\nrsync -av --quiet \\\n    --exclude='*.db' \\\n    --exclude='*.db-shm' \\\n    --exclude='*.db-wal' \\\n    \"$SOURCE_OPENCLAW/flows/\" \"./flows/\" 2>/dev/null || true\n\nrsync -av --quiet \\\n    \"$SOURCE_OPENCLAW/devices/\" \"./devices/\" 2>/dev/null || true\n\nrsync -av --quiet \\\n    \"$SOURCE_OPENCLAW/delivery-queue/\" \"./delivery-queue/\" 2>/dev/null || true\n\nrsync -av --quiet \\\n    --exclude='memory/lancedb-pro' \\\n    \"$SOURCE_OPENCLAW/memory/\" \"./memory/\" 2>/dev/null || true\n\n# 同步 skills\nrsync -av --quiet \\\n    --exclude='node_modules' \\\n    \"$SOURCE_OPENCLAW/skills/\" \"./skills/\" 2>/dev/null || true\n\n# 同步 OpenViking 关键数据（不含 _system 和 bot）\nrsync -av --quiet \\\n    --exclude='_system' \\\n    --exclude='bot' \\\n    --exclude='.openviking.pid' \\\n    \"$SOURCE_OPENVIKING/\" \"./openviking/\"\n\n# 提交\ngit add -A\nif git diff --cached --quiet; then\n    echo \"[$TODAY] No changes\"\nelse\n    git commit -m \"Full backup $TODAY\"\n    git push --quiet origin main\n    git tag -a \"backup-$TODAY\" -m \"Full backup $TODAY\"\n    git push origin \"backup-$TODAY\" --quiet\n    echo \"[$TODAY] Backup complete\"\nfi","cwd":"/home/halei/.openclaw/workspace"},"isError":false,"timestamp":1775784620316}}
