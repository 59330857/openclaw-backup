{"type":"message","id":"87ec62bc","parentId":"4e3a24d3","timestamp":"2026-04-19T05:14:53.542Z","message":{"role":"toolResult","toolCallId":"call_function_2pdruczucdeo_1","toolName":"exec","content":[{"type":"text","text":"\"use strict\";\n/**\n * Copyright (c) 2026 ByteDance Ltd. and/or its affiliates\n * SPDX-License-Identifier: MIT\n *\n * auto-auth.ts вҖ” е·Ҙе…·еұӮиҮӘеҠЁжҺҲжқғеӨ„зҗҶгҖӮ\n *\n * еҪ“ OAPI е·Ҙе…·йҒҮеҲ°жҺҲжқғй—®йўҳж—¶пјҢзӣҙжҺҘеңЁе·Ҙе…·еұӮеӨ„зҗҶпјҢдёҚеҶҚи®© AI еҲӨж–ӯпјҡ\n *\n * - UserAuthRequiredError (appScopeVerified=true)\n *   вҶ’ зӣҙжҺҘи°ғз”Ё executeAuthorize еҸ‘иө· OAuth Device Flow еҚЎзүҮ\n *\n * - UserScopeInsufficientError\n *   вҶ’ зӣҙжҺҘи°ғз”Ё executeAuthorizeпјҲдҪҝз”Ё missingScopesпјү\n *\n * - AppScopeMissingError\n *   вҶ’ еҸ‘йҖҒеә”з”Ёжқғйҷҗеј•еҜјеҚЎзүҮпјӣз”ЁжҲ·зӮ№еҮ»\"жҲ‘е·Іе®ҢжҲҗ\"еҗҺпјҡ\n *     1. жӣҙж–°еҚЎзүҮдёәеӨ„зҗҶдёӯзҠ¶жҖҒ\n *     2. invalidateAppScopeCache\n *     3. еҸ‘йҖҒдёӯй—ҙеҗҲжҲҗж¶ҲжҒҜе‘ҠзҹҘ AIпјҲ\"еә”з”Ёжқғйҷҗе·ІзЎ®и®ӨпјҢжӯЈеңЁеҸ‘иө·з”ЁжҲ·жҺҲжқғ...\"пјү\n *     4. и°ғз”Ё executeAuthorize еҸ‘иө· OAuth Device Flow\n *\n * - е…¶д»–жғ…еҶөпјҲAppScopeCheckFailedErrorгҖҒappScopeVerified=false зӯүпјү\n *   вҶ’ еӣһйҖҖеҲ°еҺҹ handleInvokeErrorпјҲдёҚи§ҰеҸ‘иҮӘеҠЁжҺҲжқғпјү\n *\n * йҷҚзә§зӯ–з•ҘпјҲдҝқе®Ҳпјүпјҡд»ҘдёӢжғ…еҶөеқҮеӣһйҖҖеҲ° handleInvokeErrorпјҡ\n * - ж—  LarkTicketпјҲйқһж¶ҲжҒҜеңәжҷҜпјү\n * - ж—  senderOpenIdпјҲж— жі•зЎ®е®ҡжҺҲжқғеҜ№иұЎпјү\n * - иҙҰеҸ·жңӘй…ҚзҪ®пјҲ!acct.configuredпјү\n * - д»»дҪ•жӯҘйӘӨжҠӣеҮәејӮеёё\n */\nObject.defineProperty(exports, \"__esModule\", { value: true });\nexports.handleCardAction = handleCardAction;\nexports.handleInvokeErrorWithAutoAuth = handleInvokeErrorWithAutoAuth;\nconst lark_ticket_1 = require(\"../core/lark-ticket.js\");\nconst lark_logger_1 = require(\"../core/lark-logger.js\");\nconst log = (0, lark_logger_1.larkLogger)('tools/auto-auth');\nconst api_error_1 = require(\"../core/api-error.js\");\nconst accounts_1 = require(\"../core/accounts.js\");\nconst tool_client_1 = require(\"../core/tool