{"type":"message","id":"1d1b6217","parentId":"f95e983e","timestamp":"2026-05-09T10:21:50.186Z","message":{"role":"toolResult","toolCallId":"call_function_4qxcewniy40a_1","toolName":"exec","content":[{"type":"text","text":"sorftime-mcp\n\n  /**\n   * 授权失败\n   */\n  function NotAuthorization();\n      {\n        \"type\": \"object\"\n      }\n\n  Examples:\n    mcporter call sorftime-mcp.NotAuthorization()\n\n  1 tool · 997ms · HTTP https://mcp.sorftime.com/?key=sutbzf…ut09"}],"details":{"status":"completed","exitCode":0,"durationMs":1514,"aggregated":"sorftime-mcp\n\n  /**\n   * 授权失败\n   */\n  function NotAuthorization();\n      {\n        \"type\": \"object\"\n      }\n\n  Examples:\n    mcporter call sorftime-mcp.NotAuthorization()\n\n  1 tool · 997ms · HTTP https://mcp.sorftime.com/?key=sutbzfpknxhnaxrnzlczdddonutyut09","cwd":"/home/halei/workspace-tts"},"isError":false,"timestamp":1778322110186}}
