undefined ? { body: JSON.stringify(options.body) } : {}),\n    });\n    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n    const data = (await resp.json());\n    // 飞书 API 统一错误模式：code !== 0\n    if (data.code !== undefined && data.code !== 0) {\n        const err = new Error(data.msg ?? `Lark API error: code=${data.code}`);\n        // eslint-disable-next-line @typescript-eslint/no-explicit-any\n        err.code = data.code;\n\n[7 more lines in file. Use offset=61 to continue.]"}],"isError":false,"timestamp":1776831811604}}
