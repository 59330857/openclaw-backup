   \"memory-core\": {\n            \"enabled\": true,\n            \"config\": {\n              \"dreaming\": {\n                \"enabled\": true\n              }\n            }\n          },\n          \"minimax\": {\n            \"enabled\": true,\n            \"config\": {}\n          },\n          \"feishu\": {\n            \"enabled\": false,\n            \"config\": {}\n          },\n          \"openclaw-weixin\": {\n            \"enabled\": true,\n            \"config\": {}\n          },\n          \"wecom-openclaw-plugin\": {\n            \"enabled\": true,\n            \"config\": {}\n          },\n          \"browser\": {\n            \"enabled\": true,\n            \"config\": {}\n          },\n          \"openrouter\": {\n            \"enabled\": true,\n            \"config\": {}\n          },\n          \"openclaw-lark\": {\n            \"enabled\": true,\n            \"config\": {}\n          },\n          \"workboard\": {\n            \"enabled\": true,\n            \"config\": {}\n          }\n        },\n        \"bundledDiscovery\": \"compat\"\n      },\n      \"cron\": {\n        \"maxConcurrentRuns\": 8\n      }\n    },\n    \"hash\": \"fc1f560a97cb99177c3441885011e8f880222a25cf924227a962214f8a6c22ce\",\n    \"issues\": [],\n    \"warnings\": [\n      {\n        \"path\": \"plugins.entries.feishu\",\n        \"message\": \"plugin feishu: duplicate plugin id detected; global plugin will be overridden by global plugin (/home/halei/.openclaw/npm/projects/openclaw-feishu-dc69f44688/node_modules/@openclaw/feishu/dist/index.js)\"\n      },\n      {\n        \"path\": \"plugins.entries.feishu\",\n        \"message\": \"plugin disabled (disabled in config) but config is present\"\n      }\n    ],\n    \"legacyIssues\": []\n  }\n}[... 118918 more characters truncated; rerun with narrower args if needed]"}],"details":{"persistedDetailsTruncated":true,"originalDetailsBytesAtLeast":8193,"originalDetailKeys":["ok","result"]},"isError":false,"timestamp":17809