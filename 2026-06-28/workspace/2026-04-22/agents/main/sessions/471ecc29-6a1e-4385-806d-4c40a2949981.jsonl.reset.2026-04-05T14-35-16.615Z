tatus_get\",\n                \"parameters\": [\n                    {\n                        \"name\": \"x-api-key\",\n                        \"in\": \"header\",\n                        \"required\": false,\n                        \"schema\": {\n                            \"anyOf\": [\n                                {\n                                    \"type\": \"string\"\n                                },\n                                {\n                                    \"type\": \"null\"\n                                }\n                            ],\n                            \"title\": \"X-Api-Key\"\n                        }\n                    },\n                    {\n                        \"name\": \"authorization\",\n                        \"in\": \"header\",\n                        \"required\": false,\n                        \"schema\": {\n                            \"anyOf\": [\n                                {","cwd":"/home/halei/.openclaw/workspace"},"isError":false,"timestamp":1775285084244}}
