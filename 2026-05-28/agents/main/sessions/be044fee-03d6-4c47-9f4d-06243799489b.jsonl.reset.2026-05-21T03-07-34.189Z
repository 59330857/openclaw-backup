tanding Language","help":"Preferred language hint for audio understanding/transcription when provider support is available. Set this to improve recognition accuracy for known primary languages.","tags":["media","tools"]},"hintPath":"tools.media.audio.language"},{"key":"providerOptions","path":"tools.media.audio.providerOptions","type":"object","required":false,"hasChildren":true},{"key":"deepgram","path":"tools.media.audio.deepgram","type":"object","required":false,"hasChildren":true},{"key":"baseUrl","path":"tools.media.audio.baseUrl","type":"string","required":false,"hasChildren":false,"hint":{"tags":["media","tools","url-secret"]},"hintPath":"tools.media.audio.baseUrl"},{"key":"headers","path":"tools.media.audio.headers","type":"object","required":false,"hasChildren":true},{"key":"request","path":"tools.media.audio.request","type":"object","required":false,"hasChildren":true,"hint":{"label":"Audio Request Overrides","help":"Low-level HTTP request overrides for audio providers, including custom headers, auth, proxy routing, and TLS client settings. Use this for proxy-backed or self-hosted transcription endpoints when plain baseUrl/apiKey fields are not enough.","tags":["media","tools"]},"hintPath":"tools.media.audio.request"},{"key":"attachments","path":"tools.media.audio.attachments","type":"object","required":false,"hasChildren":true,"hint":{"label":"Audio Understanding Attachment Policy","help":"Attachment policy for audio inputs indicating which uploaded files are eligible for audio processing. Keep restrictive defaults in mixed-content channels to avoid unintended audio workloads.","tags":["media","tools"]},"hintPath":"tools.media.audio.attachments"},{"key":"models","path":"tools.media.audio.models","type":"array","required":false,"hasChildren":true,"hint":{"label":"Audio Understanding Models","help":"Ordered model preferences specifically for audio understanding, used before shared media model fallback. Choose models optimized for transcription quality in your primary language/domain.","tags":["models","media","tools"]},"hintPath":"tools.media.audio.models"},{"key":"echoTranscript","path":"tools.media.audio.echoTranscript","type":"boolean","required":false,"hasChildren":false,"hint":{"label":"Echo Transcript to Chat","help":"Echo the audio transcript back to the originating chat before agent processing. When enabled, users immediately see what was heard from their voice note, helping them verify transcription accuracy before the agent acts on it. Default: false.","tags":["media","tools"]},"hintPath":"tools.media.audio.echoTranscript"},{"key":"echoFormat","path":"tools.media.audio.echoFormat","type":"string","required":false,"hasChildren":false,"hint":{"label":"Transcript Echo Format","help":"Format string for the echoed transcript message. Use `{transcript}` as a placeholder for the transcribed text. Default: '📝 \"{transcript}\"'.","tags":["media","tools"]},"hintPath":"tools.media.audio.echoFormat"}]}},"isError":false,"timestamp":1779244497934}}
