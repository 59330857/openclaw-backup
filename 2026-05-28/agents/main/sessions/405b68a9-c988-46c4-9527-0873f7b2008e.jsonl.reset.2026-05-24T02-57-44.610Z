{"type":"message","id":"4c249ab3","parentId":"4835d797","timestamp":"2026-05-23T13:51:06.694Z","message":{"role":"toolResult","toolCallId":"call_function_q294ymcptnct_1","toolName":"exec","content":[{"type":"text","text":"=== 全部 bindings ===\n  type=route agentId=main match={'accountId': 'kiit', 'channel': 'feishu'}\n  type=route agentId=agent-orchestrator match={'accountId': 'agent-orchestrator', 'channel': 'feishu'}\n  type=route agentId=content match={'accountId': 'content', 'channel': 'feishu'}\n  type=route agentId=traffic match={'channel': 'feishu', 'accountId': 'traffic'}\n  type=route agentId=ops match={'channel': 'feishu', 'accountId': 'ops'}\n  type=route agentId=director match={'channel': 'feishu', 'accountId': 'director'}\n  type=route agentId=finance match={'channel': 'feishu', 'accountId': 'finance'}\n  type=route agentId=review match={'channel': 'feishu', 'accountId': 'review'}\n  type=route agentId=koc match={'channel': 'feishu', 'accountId': 'koc'}\n  type=route agentId=tts match={'accountId': 'tts', 'channel': 'feishu'}"}],"details":{"status":"completed","exitCode":0,"durationMs":56,"aggregated":"=== 全部 bindings ===\n  type=route agentId=main match={'accountId': 'kiit', 'channel': 'feishu'}\n  type=route agentId=agent-orchestrator match={'accountId': 'agent-orchestrator', 'channel': 'feishu'}\n  type=route agentId=content match={'accountId': 'content', 'channel': 'feishu'}\n  type=route agentId=traffic match={'channel': 'feishu', 'accountId': 'traffic'}\n  type=route agentId=ops match={'channel': 'feishu', 'accountId': 'ops'}\n  type=route agentId=director match={'channel': 'feishu', 'accountId': 'director'}\n  type=route agentId=finance match={'channel': 'feishu', 'accountId': 'finance'}\n  type=route agentId=review match={'channel': 'feishu', 'accountId': 'review'}\n  type=route agentId=koc match={'channel': 'feishu', 'accountId': 'koc'}\n  type=route agentId=tts match={'accountId': 'tts', 'channel': 'feishu'}","cwd":"/home/halei/.openclaw/worksp