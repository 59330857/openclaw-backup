{"type":"message","id":"ffb3c3b0","parentId":"6ab9ae49","timestamp":"2026-05-24T02:51:49.928Z","message":{"role":"toolResult","toolCallId":"call_function_xa7vbkdtzyiw_1","toolName":"exec","content":[{"type":"text","text":"function tiktok_category_report(nodeId: string, site?: \"Unknow\" | \"US\" | \"MY\" | \"PH\" | \"VN\" | \"ID\" | \"GB\");\n      {\n        \"type\": \"object\",\n        \"properties\": {\n          \"nodeId\": {\n            \"description\": \"类目市场nodeid，可通过TiktokCategoryNameSearch获得\",\n            \"type\": \"string\"\n          },\n          \"site\": {\n            \"description\": \"TikTok站点\",\n            \"type\": \"string\",\n            \"enum\": [\n              \"Unknow\",\n              \"US\",\n              \"MY\",\n              \"PH\",\n              \"VN\",\n              \"ID\",\n              \"GB\"\n            ],\n            \"default\": \"Unknow\"\n          }\n        },\n        \"required\": [\n          \"nodeId\"\n        ]\n      }\n\n  /**\n   * 查询亚马逊平台上类目产品的特点\n   *\n   * @param productName 查询的类目名称\n   * @param amzSite? 亚马逊站点\n   */\n  function similar_product_feature(productName: string, amzSite?: \"Unknow\" | \"US\" | \"GB\" | \"DE\" | \"FR\" | \"IN\" | \"CA\" | \"JP\" | \"ES\" | \"IT\" | \"MX\" | \"AE\" | \"AU\" | \"BR\" | \"SA\");\n      {\n        \"type\": \"object\",\n        \"properties\": {\n          \"productName\": {\n            \"description\": \"查询的类目名称\",\n            \"type\": \"string\"\n          },\n          \"amzSite\": {\n            \"description\": \"亚马逊站点\",\n            \"type\": \"string\",\n            \"enum\": [\n              \"Unknow\",\n              \"US\",\n              \"GB\",\n              \"DE\",\n              \"FR\",\n              \"IN\",\n              \"CA\",\n              \"JP\",\n              \"ES\",\n              \"IT\",\n              \"MX\",\n              \"AE\",\n              \"AU\",\n              \"BR\",\n              \"SA\"\n            ],\n            \"default\": \"Unknow\"\n          }\n        },\n        \"required\": [\n          \"productName\"\n        ]\n      }\n\n  /**\n   * 查询沃尔玛电商平台上实时热搜关键词榜，按月搜索量排序\n   *\n   * @param rank_min 排名范围起始值（如：1）\n   * @param rank_max 排名范围结束值（如：100）\n   * @param page? 查询结果的页码索引，默认为第1页。每页返回20条数据\n   */\n  function walmart_keyword_list(rank_min: number, rank_max: number, page?: number);\n      {\n        \"type\": \"object\",\n        \"properties\": {\n          \"rank_min\": {\n            \"description\": \"排名范围起始值（如：1）\",\n            \"type\": \"integer\"\n          },\n          \"rank_max\": {\n            \"description\": \"排名范围结束值（如：100）\",\n            \"type\": \"integer\"\n          },\n          \"page\": {\n            \"description\": \"查询结果的页码索引，默认为第1页。每页返回20条数据\",\n            \"type\": \"integer\",\n            \"default\": 1\n          }\n        },\n        \"required\": [\n          \"rank_min\",\n          \"rank_max\"\n        ]\n      }\n\n  /**\n   * 查询我的亚马逊平台关键词词库的词\n   *\n   * @param dict? 选填，如果指定，查询指定收藏夹下的词；如需查询全部词，指定传值`all`\n   * @param page? 查询结果的页码索引，默认为第1页。每页返回50条数据\n   * @param keywordSupportSite? 亚马逊站点\n   */\n  function get_favorite_keyword(dict?: string, page?: number, keywordSupportSite?: \"Unknow\" | \"US\" | \"GB\" | \"DE\" | \"FR\" | \"CA\" | \"JP\" | \"ES\" | \"IT\" | \"MX\" | \"AE\" | \"AU\" | \"BR\" | \"SA\");\n      {\n        \"type\": \"object\",\n        \"properties\": {\n          \"dict\": {\n            \"description\": \"选填，如果指定，查询指定收藏夹下的词；如需查询全部词，指定传值`all`\",\n            \"type\": \"string\",\n            \"default\": \"\"\n          },\n          \"page\": {\n            \"description\": \"查询结果的页码索引，默认为第1页。每页返回50条数据\",\n            \"type\": \"integer\",\n            \"default\": 1\n          },\n          \"keywordSupportSite\": {\n            \"description\": \"亚马逊站点\",\n            \"type\": \"string\",\n            \"enum\": [\n              \"Unknow\",\n              \"US\",\n              \"GB\",\n              \"DE\",\n              \"FR\",\n              \"CA\",\n              \"JP\",\n              \"ES\",\n              \"IT\",\n              \"MX\",\n              \"AE\",\n              \"AU\",\n              \"BR\",\n              \"SA\"\n            ],\n            \"default\": \"Unknow\"\n          }\n        }\n      }\n\n  /**\n   * 查询我的沃尔玛平台关键词词库的词\n   *\n   * @param dict? 选填，如果指定，查询指定收藏夹下的词；如需查询全部词，指定传值`all`\n   * @param page? 查询结果的页码索引，默认为第1页。每页返回100条数据\n   */\n  function walmart_get_favorite_keyword(dict?: string, page?: number);\n      {\n        \"type\": \"object\",\n        \"properties\": {\n          \"dict\": {\n            \"description\": \"选填，如果指定，查询指定收藏夹下的词；如需查询全部词，指定传值`all`\",\n            \"type\": \"string\",\n            \"default\": \"\"\n          },\n          \"page\": {\n            \"description\": \"查询结果的页码索引，默认为第1页。每页返回100条数据\",\n            \"type\": \"integer\",\n            \"default\": 1\n          }\n        }\n      }\n\n  /**\n   * 查询亚马逊电商平台上热搜关键词搜索结果自然位产品清单\n   *\n   * @param keyword 查询的关键词\n   * @param page? 查询结果的页码索引，默认为第1页。每页返回20条数据\n   * @param keywordSupportSite? 亚马逊站点\n   */\n  function keyword_search_results(keyword: string, page?: number, keywordSupportSite?: \"Unknow\" | \"US\" | \"GB\" | \"DE\" | \"FR\" | \"CA\" | \"JP\" | \"ES\" | \"IT\" | \"MX\" | \"AE\" | \"AU\" | \"BR\" | \"SA\");\n      {\n        \"type\": \"object\",\n        \"properties\": {\n          \"keyword\": {\n            \"description\": \"查询的关键词\",\n            \"type\": \"string\"\n          },\n          \"page\": {\n            \"description\": \"查询结果的页码索引，默认为第1页。每页返回20条数据\",\n            \"type\": \"integer\",\n            \"default\": 1\n          },\n          \"keywordSupportSite\": {\n            \"description\": \"亚马逊站点\",\n            \"type\": \"string\",\n            \"enum\": [\n              \"Unknow\",\n              \"US\",\n              \"GB\",\n              \"DE\",\n              \"FR\",\n              \"CA\",\n              \"JP\",\n              \"ES\",\n--\n  function tiktok_similar_product(searchName: string, page?: number, site?: \"Unknow\" | \"US\" | \"MY\" | \"PH\" | \"VN\" | \"ID\" | \"GB\");\n      {\n        \"type\": \"object\",\n        \"properties\": {\n          \"searchName\": {\n            \"description\": \"查询的产品名称\",\n            \"type\": \"string\"\n          },\n          \"page\": {\n            \"description\": \"查询结果的页码索引，默认为第1页。每页返回20条数据\",\n            \"type\": \"integer\",\n            \"default\": 1\n          },\n          \"site\": {\n            \"description\": \"TikTok站点\",\n            \"type\": \"string\",\n            \"enum\": [\n              \"Unknow\",\n              \"US\",\n              \"MY\",\n              \"PH\",\n              \"VN\",\n              \"ID\",\n              \"GB\"\n            ],\n            \"default\": \"Unknow\"\n          }\n        },\n        \"required\": [\n          \"searchName\"\n        ]\n      }\n\n  /**\n   * 获取当前时间\n   */\n  function get_time();\n      {\n        \"type\": \"object\",\n        \"properties\": {}\n      }\n\n  /**\n   * 查询亚马逊电商平台上历史日期的热搜关键词榜，按周搜索量排序\n   *\n   * @param date 所查询的时间，格式yyyy-MM-dd，最早支持2025-03-04\n   * @param rank_min? 可选参数，如果指定表示筛选周搜索量排名大于等于此值的关键词\n   * @param rank_max? 可选参数，如果指定表示筛选周搜索量排名小于等于此值的关键词\n   * @param search_volume_min? 可选参数，如果指定表示筛选周搜索量大于等于此值的关键词\n   * @param search_volume_max? 可选参数，如果指定表示筛选周搜索量小于等于此值的关键词\n   * @param page? 查询结果的页码索引，默认为第1页。每页返回20条数据\n   * @param keywordSupportSite? 亚马逊站点\n   */\n  function keyword_list_from_history(date: string, rank_min?: number, rank_max?: number, search_volume_min?: number, search_volume_max?: number);\n  // optional (2): page, keywordSupportSite\n      {\n        \"type\": \"object\",\n        \"properties\": {\n          \"date\": {\n            \"description\": \"所查询的时间，格式yyyy-MM-dd，最早支持2025-03-04\",\n            \"type\": \"string\"\n          },\n          \"rank_min\": {\n            \"description\": \"可选参数，如果指定表示筛选周搜索量排名大于等于此值的关键词\",\n            \"type\": \"integer\",\n            \"default\": -9999\n          },\n          \"rank_max\": {\n            \"description\": \"可选参数，如果指定表示筛选周搜索量排名小于等于此值的关键词\",\n            \"type\": \"integer\",\n            \"default\": -9999\n          },\n          \"search_volume_min\": {\n            \"description\": \"可选参数，如果指定表示筛选周搜索量大于等于此值的关键词\",\n            \"type\": \"integer\",\n            \"default\": -9999\n          },\n          \"search_volume_max\": {\n            \"description\": \"可选参数，如果指定表示筛选周搜索量小于等于此值的关键词\",\n            \"type\": \"integer\",\n            \"default\": -9999\n          },\n          \"page\": {\n            \"description\": \"查询结果的页码索引，默认为第1页。每页返回20条数据\",\n            \"type\": \"integer\",\n            \"default\": 1\n          },\n          \"keywordSupportSite\": {\n            \"description\": \"亚马逊站点\",\n            \"type\": \"string\",\n            \"enum\": [\n              \"Unknow\",\n              \"US\",\n              \"GB\",\n              \"DE\",\n              \"FR\",\n              \"CA\",\n              \"JP\","}],"details":{"persistedDetailsTruncated":true,"originalDetailsBytesAtLeast":10719,"originalDetailKeys":["status","exitCode","durationMs","aggregated","cwd"],"status":"completed","cwd":"/home/halei/workspace-tts","exitCode":0},"isError":false,"timestamp":1779591109925}}
