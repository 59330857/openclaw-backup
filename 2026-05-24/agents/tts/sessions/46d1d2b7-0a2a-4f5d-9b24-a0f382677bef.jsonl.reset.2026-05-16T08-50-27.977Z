  -d \"{\\\"app_id\\\":\\\"$APP_ID\\\",\\\"app_secret\\\":\\\"$APP_SECRET\\\"}\" | python3 -c \"import json,sys; d=json.load(sys.stdin); print(d.get('tenant_access_token',''))\")\n\n# Try with 商品名称 (text field) + 售价本地货币 (number field) without formatter\ncurl -s -X POST \"https://open.feishu.cn/open-apis/bitable/v1/apps/AKppbAeyXanToTsVl6ScxO5QnZd/tables/tblHU2do30jzinJT/records\" \\\n  -H \"Authorization: Bearer $TOKEN\" \\\n  -H \"Content-Type: application/json; charset=utf-8\" \\\n  --data-raw '{\n    \"fields\": {\n      \"文本\": \"2026-05-15 测试-商品+价格\",\n      \"商品名称\": \"Lò xo cột tóc thailann phồng tóc - 越南爆款测试\",\n      \"售价本地货币\": 59000\n    }\n  }' | python3 -m json.tool 2>&1"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":479,"output":630,"cacheRead":100480,"cacheWrite":0,"totalTokens":101589,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1778853581578,"responseId":"065659ce67ace7a3c87e266a5b26bbfe"}}
