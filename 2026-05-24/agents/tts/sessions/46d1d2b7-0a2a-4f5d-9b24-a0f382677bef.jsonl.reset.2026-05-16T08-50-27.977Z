nZd/tables/tblHU2do30jzinJT/records\"\n\ndef post_record(fields):\n    payload = {\"fields\": fields}\n    data = json.dumps(payload, ensure_ascii=False).encode('utf-8')\n    req = urllib.request.Request(\n        base_url, data=data,\n        headers={'Authorization': f'Bearer {TOKEN}', 'Content-Type': 'application/json; charset=utf-8'},\n        method='POST'\n    )\n    try:\n        with urllib.request.urlopen(req) as r:\n            resp = json.loads(r.read())\n            if resp.get('code') == 0:\n                return f\"✅ OK: {resp['data']['record']['id']}\"\n            else:\n                return f\"❌ {resp.get('code')} {resp.get('msg')}\"\n    except urllib.error.HTTPError as e:\n        return f\"❌ HTTP {e.code}: {e.read().decode()[:200]}\"\n\n# Test all problematic fields with CORRECT names\nprint(\"=== Testing ALL fields (correct names) ===\")\nall_fields = {\n    \"文本\": \"2026-05-15 完整测试-正确字段名\",\n    \"商品名称\": \"Kẹp Càng Cua Voan Đính Đá - 完整测试\",\n    \"售价（本地货币）\": 69999,\n    \"月销量\": 5333,\n    \"增长率\": -14.3,\n    \"1688价格(CNY)\": 8.5,\n    \"预估利润\": 22.5,\n    \"利润率(%)\": 32.1,\n    \"三级类目\": \"发夹\",\n    \"站点\": \"VN\",\n    \"推荐等级\": \"A\",\n    \"采集状态\": \"已采集\",\n    \"IP风险\": \"无\",\n    \"行动建议\": \"正常采购首选30-50件\",\n    \"1688同款链接\": \"https://detail.1688.com/offer/123456.html\",\n}\n\nresult = post_record(all_fields)\nprint(f\"Full record: {result}\")\n\n# Test individually\nprint(\"\\n=== Individual tests ===\")\ntests = [\n    (\"售价（本地货币）\", 69999),\n    (\"1688价格(CNY)\", 8.5),\n    (\"预估利润\", 22.5),\n    (\"利润率(%)\", 32.1),\n    (\"1688同款链接\", \"https://detail.1688.com/offer/999111.html\"),\n]\nfor fname, fvalue in tests:\n    print(f\"  {fname}: {post_record({'文本': '2026-05-15', '商品名称': f'Test {fname}', fname: fvalue})}\")","path":"/tmp/test_feishu6.py"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":532,"output":1076,"cacheRead":111936,"cacheWrite":0,"totalTokens":113544,"cost":{"input":